    content: "";
    position: absolute;
    inset: 0;
    background: url("/images/hero-pattern.svg") center center / cover no-repeat;
    opacity: 0.95;
    mix-blend-mode: screen;
    pointer-events: none;
    z-index: 0;
  }

  .ayan-hero::before {
    z-index: 0;
  }

  .ayan-hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-copy,
  .hero-person-area {
    position: relative;
    z-index: 2;
  }

  .hero-person img {
    filter: drop-shadow(0 20px 42px rgba(0, 0, 0, 0.36));
  }

  .article-card:nth-child(1) .article-thumb {
    width: 142px;
    min-height: 142px;
