---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="站内搜索｜阿岩跨境笔记" description="搜索阿岩跨境笔记中的亚马逊 AI 运营、PPC、Listing、选品和工具模板内容。">
  <main class="search-page">
    <section class="search-hero">
      <div class="search-kicker">Search</div>
      <h1>站内搜索</h1>
      <p>搜索亚马逊 AI 运营、广告 PPC、Listing 优化、选品指南和工具模板。</p>
    </section>

    <section class="search-card">
      <div id="search"></div>
    </section>
  </main>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

  <script type="module">
    import { PagefindUI } from "/pagefind/pagefind-ui.js";

    new PagefindUI({
      element: "#search",
      showSubResults: true,
      showImages: false,
      excerptLength: 24,
      translations: {
        placeholder: "搜索 AI 运营、PPC、Listing、选品……",
        clear_search: "清空",
        load_more: "加载更多",
        search_label: "站内搜索",
        filters_label: "筛选",
        zero_results: "没有找到相关内容",
        many_results: "找到 [COUNT] 条结果",
        one_result: "找到 1 条结果",
        alt_search: "没有找到 [SEARCH_TERM]，显示 [DIFFERENT_TERM] 的结果",
        search_suggestion: "搜索 [SEARCH_TERM]"
      }
    });
  </script>
</BaseLayout>

<style>
  .search-page {
    min-height: 100vh;
    padding: 56px 24px 80px;
    background:
      radial-gradient(circle at 24% 14%, rgba(19, 104, 255, 0.08), transparent 26%),
      linear-gradient(180deg, #f6f9fd 0%, #eef3fa 100%);
  }

  .search-hero {
    max-width: 960px;
    margin: 0 auto 24px;
  }

  .search-kicker {
    display: inline-flex;
    align-items: center;
    height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: #eef5ff;
    color: #1368ff;
    border: 1px solid #dceaff;
    font-size: 13px;
    font-weight: 900;
    margin-bottom: 14px;
  }

  .search-hero h1 {
    margin: 0;
    color: #0f172a;
    font-size: 44px;
    line-height: 1.16;
    letter-spacing: -1px;
  }

  .search-hero p {
    max-width: 720px;
    margin: 14px 0 0;
    color: #64748b;
    font-size: 17px;
    line-height: 1.8;
  }

  .search-card {
    max-width: 960px;
    margin: 0 auto;
    padding: 26px;
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(226, 232, 240, 0.96);
    box-shadow:
      0 24px 80px rgba(15, 23, 42, 0.08),
      inset 0 1px 0 rgba(255,255,255,0.95);
  }

  :global(.pagefind-ui) {
    --pagefind-ui-primary: #1368ff;
    --pagefind-ui-text: #0f172a;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #dce6f5;
    --pagefind-ui-tag: #eef5ff;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 14px;
    --pagefind-ui-font: inherit;
  }

  :global(.pagefind-ui__search-input) {
    height: 52px;
    font-size: 16px;
  }

  :global(.pagefind-ui__result) {
    padding: 22px 0;
  }

  :global(.pagefind-ui__result-title) {
    font-weight: 900;
  }

  @media (max-width: 720px) {
    .search-page {
      padding: 34px 14px 56px;
    }

    .search-hero h1 {
      font-size: 34px;
    }

    .search-card {
      padding: 18px;
      border-radius: 22px;
    }
  }
</style>