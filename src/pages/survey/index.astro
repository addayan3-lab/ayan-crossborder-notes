<BaseLayout title="30 秒资料诊断｜阿岩跨境笔记" description="回答几个问题，帮你判断目前更适合领取哪份亚马逊运营资料包：关键词表、Listing 清单、PPC 模板还是选品矩阵。">
  <main class="survey-page">
    <section class="survey-hero">
      <h1>30 秒资料诊断</h1>
      <p>回答几个问题，看看你现在更适合哪份亚马逊运营资料。</p>
    </section>

    <section class="survey-card">
      <div id="survey-step-1" class="survey-step">
        <div class="survey-step-header">
          <span class="survey-step-num">问题 1/2</span>
          <span class="survey-step-label">你现在处在哪个阶段？</span>
        </div>
        <div class="survey-options" id="survey-q1">
          {stageOptions.map((opt) => (
            <label class="survey-option" data-value={opt.value}>
              <input type="radio" name="stage" value={opt.value} />
              <span class="survey-option-text">{opt.label}</span>
            </label>
          ))}
        </div>
        <button class="survey-next" id="survey-next-1" type="button" disabled>下一步</button>
      </div>

      <div id="survey-step-2" class="survey-step" hidden>
        <div class="survey-step-header">
          <span class="survey-step-num">问题 2/2</span>
          <span class="survey-step-label">你最想先解决什么？</span>
        </div>
        <div class="survey-options" id="survey-q2">
          {goalOptions.map((opt) => (
            <label class="survey-option" data-value={opt.value}>
              <input type="radio" name="goal" value={opt.value} />
              <span class="survey-option-text">{opt.label}</span>
            </label>
          ))}
        </div>
        <button class="survey-next" id="survey-next-2" type="button" disabled>查看推荐</button>
      </div>

      <div id="survey-result" class="survey-result" hidden>
        <div class="survey-result-header">
          <span class="survey-result-badge">推荐结果</span>
          <h2 id="survey-result-name"></h2>
          <p id="survey-result-audience" class="survey-result-audience"></p>
        </div>

        <div class="survey-result-section">
          <h3>推荐资料包</h3>
          <a id="survey-result-link" class="survey-result-cta" target="_blank" rel="noopener noreferrer">
            查看资料详情 →
          </a>
          <a href="/lead/" class="survey-result-lead" target="_blank" rel="noopener noreferrer">
            立即领取资料 →
          </a>
        </div>

        <div class="survey-result-section">
          <h3>推荐文章</h3>
          <div id="survey-result-articles" class="survey-result-articles"></div>
        </div>

        <div class="survey-result-section">
          <h3>推荐公开课</h3>
          <div id="survey-result-open-class"></div>
        </div>

        <div class="survey-result-actions">
          <a href="/ask/" class="survey-result-secondary">继续问 AI 阿岩助手 →</a>
          <a href="/resources/" class="survey-result-back">返回资源中心</a>
        </div>

        <div class="survey-disclaimer">
          <strong>说明：</strong>这是学习路径推荐，不替代真实运营判断。建议结合你的实际产品和阶段选择最适合的资料。
        </div>
      </div>

      <div id="survey-no-match" class="survey-no-match" hidden>
        <p>根据你的选择，暂时没有找到最匹配的资料。建议试试 AI 阿岩助手的个性化推荐。</p>
        <a href="/ask/" class="survey-result-secondary">问 AI 阿岩助手 →</a>
      </div>
    </section>
  </main>

  <script type="module">
    const results = JSON.parse(document.getElementById("survey-results-data").textContent);

    function setupStep(stepId, nextId, name) {
      const step = document.querySelector("#" + stepId);
      const next = document.querySelector("#" + nextId);
      if (!step || !next) return;
      const radios = step.querySelectorAll('input[type="radio"]');
      radios.forEach((radio) => {
        radio.addEventListener("change", () => {
          next.disabled = false;
        });
      });
      next.addEventListener("click", () => {
        const selected = step.querySelector('input[type="radio"]:checked');
        if (!selected) return;
        window._surveyAnswers = window._surveyAnswers || {};
        window._surveyAnswers[name] = selected.value;
        const current = step.closest(".survey-step");
        if (current) current.hidden = true;
        const nextStep = current ? current.nextElementSibling : null;
        if (nextStep && nextStep.classList.contains("survey-step")) {
          nextStep.hidden = false;
        } else {
          showResult();
        }
      });
    }

    function lookup(stage, goal) {
      const rules = JSON.parse(document.getElementById("survey-rules-data").textContent);
      for (const rule of rules) {
        if (rule.stage === stage && rule.goal === goal) {
          return results[rule.resultId];
        }
      }
      const goalFirst = rules.find((r) => r.goal === goal);
      if (goalFirst) return results[goalFirst.resultId];
      const stageFirst = rules.find((r) => r.stage === stage);
      if (stageFirst) return results[stageFirst.resultId];
      return null;
    }

    function showResult() {
      const stage = window._surveyAnswers?.stage;
      const goal = window._surveyAnswers?.goal;
      const match = lookup(stage, goal);
      const resultEl = document.querySelector("#survey-result");
      const noMatchEl = document.querySelector("#survey-no-match");
      if (!match) {
        if (noMatchEl) noMatchEl.hidden = false;
        if (resultEl) resultEl.hidden = true;
        return;
      }
      if (resultEl) resultEl.hidden = false;
      if (noMatchEl) noMatchEl.hidden = true;

      const nameEl = document.querySelector("#survey-result-name");
      const audienceEl = document.querySelector("#survey-result-audience");
      const linkEl = document.querySelector("#survey-result-link");
      const articlesEl = document.querySelector("#survey-result-articles");
      const openClassEl = document.querySelector("#survey-result-open-class");

      if (nameEl) nameEl.textContent = match.name;
      if (audienceEl) audienceEl.textContent = match.audience;
      if (linkEl) linkEl.href = "/resources/" + match.slug + "/";

      if (articlesEl) {
        articlesEl.innerHTML = match.articles.map((a) =>
          '<a class="survey-result-article" href="/articles/' + a.slug + '/" target="_blank" rel="noopener noreferrer">' + a.title + '</a>'
        ).join("");
      }

      if (openClassEl && match.openClass) {
        openClassEl.innerHTML = '<a class="survey-result-article" href="/open-class/' + match.openClass.slug + '/" target="_blank" rel="noopener noreferrer">' + match.openClass.title + '</a>';
      }
    }

    setupStep("survey-step-1", "survey-next-1", "stage");
    setupStep("survey-step-2", "survey-next-2", "goal");
  </script>

  <div id="survey-results-data" style="display:none">{JSON.stringify(results)}</div>
  <div id="survey-rules-data" style="display:none">{JSON.stringify(rules)}</div>
</BaseLayout>

<style>
