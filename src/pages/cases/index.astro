---
import BaseLayout from "../../layouts/BaseLayout.astro";

const categories = [
  {
    name: "选品判断",
    desc: "产品能不能做、市场容量判断、竞品分析",
    items: [
      { title: "一个产品为什么看起来能做，但不建议继续", desc: "搜索量高的品类，品牌集中度 > 70%，新卖家进去大概率亏广告费", status: "待上线" }
    ]
  },
  {
    name: "Listing 诊断",
    desc: "有流量没转化、点击率低、CVR 低",
    items: [
      { title: "一个 Listing 有流量没转化，问题出在哪里", desc: "广告 CTR 正常但 CVR 极低，排查后发现五点写成了功能列表而不是卖点表达", status: "待上线" }
    ]
  },
  {
    name: "PPC 广告复盘",
    desc: "ACOS 高、曝光低、预算分配、搜索词分析",
    items: [
      { title: "广告 ACOS 高，先别急着关广告", desc: "ACOS 高不是广告的问题，是选词策略和 Listing 承接的问题——调竞价没用，改 Listing 才有用", status: "待上线" }
    ]
  },
  {
    name: "Review 痛点反推",
    desc: "差评归因、退货分析、产品改进方向",
    items: [
      { title: "从 50 条差评里反推出产品改进方向", desc: "差评最多的不一定是最紧急的——排名第一的改起来要 3 个月，排名第三的改起来只要 1 周", status: "待上线" }
    ]
  },
  {
    name: "新品冷启动",
    desc: "新品第一周评估、前期准备、节奏把控",
    items: [
      { title: "新品上线第一周怎么复盘", desc: "新品第一周最该看的不是 ACOS，是哪些词有点击有出单——数据是用来做判断的，不是用来焦虑的", status: "待上线" }
    ]
  }
];

const beginnerOrder = [
  { title: "选品判断案例：产品能不能做", desc: "先确认赛道有没有新卖家机会" },
  { title: "Listing 诊断案例：有流量不出单", desc: "检查页面承接是否到位" },
  { title: "PPC 广告复盘案例：ACOS 高", desc: "不要急着关广告，先查原因" },
  { title: "新品冷启动案例：上线第一周", desc: "第一周看什么、做什么" }
];

const resources = [
  { name: "选品竞品矩阵", href: "/resources/competitor-selection-matrix/", desc: "4 维度竞品对比 + 差异化机会判断" },
  { name: "Listing 自检清单", href: "/resources/listing-checklist/", desc: "覆盖标题、五点、图片、关键词的上线前逐项检查" },
  { name: "PPC 周复盘表", href: "/resources/ppc-weekly-review/", desc: "销量、广告、ACOS、关键词、Review 的周复盘模板" },
  { name: "Review 痛点分析表", href: "/resources/review-pain-analysis/", desc: "Review 痛点归类 + 高频问题提炼 + Listing 改进点" }
];

const ayanBreadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://amz.hao1234.top/" },
    { "@type": "ListItem", "position": 2, "name": "实操案例库", "item": "https://amz.hao1234.top/cases/" }
  ]
};
---
<BaseLayout title="亚马逊运营实操案例库｜阿岩跨境笔记" description="用脱敏案例拆解亚马逊选品、Listing、PPC、Review 和新品冷启动问题，帮助新手把 AI 提示词、资料表格和运营动作串起来。">
  <script type="application/ld+json" set:html={JSON.stringify(ayanBreadcrumbData)}></script>

  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero-inner">
      <h1>亚马逊运营实操案例库</h1>
      <p>每个案例都来自真实运营场景，已做脱敏处理。帮助你对照自己的情况，看清分析路径和判断过程。</p>
      <div class="hero-actions">
        <a class="cta-primary" href="#cases">浏览案例分类 →</a>
        <a class="cta-secondary" href="/survey/">做 30 秒资料诊断</a>
      </div>
      <div class="hero-links">
        <a href="/ai-prompts/">查看 AI 提示词实操库</a>
        <span class="hero-links-sep">·</span>
        <a href="/ask/">问问 AI 阿岩助手</a>
      </div>
    </div>
  </section>

  <section class="section" id="cases">
    <!-- 新手推荐案例路径 -->
    <div class="topic-intro">
      <h2>新手推荐案例路径</h2>
      <p>从最常遇到的问题开始，按顺序跟读能形成判断框架。</p>
      <ol class="beginner-order-list">
        {beginnerOrder.map((item, i) => (
          <li>
            <div class="beginner-order-item">
              <span class="beginner-order-num">{i + 1}</span>
              <span class="beginner-order-label">{item.title}</span>
              <span class="beginner-order-desc">{item.desc}</span>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <!-- 案例分类 -->
    {categories.map((group) => (
      <div class="topic-intro">
        <h2>{group.name}</h2>
        <p>{group.desc}</p>
        <div class="grid grid-3">
          {group.items.map((item) => (
            <div class="card card-pending">
              <span class="tag tag-pending">待上线</span>
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    ))}

    <!-- 全部案例预告 -->
    <div class="topic-intro">
      <h2>全部案例</h2>
      <p>首批 5 篇案例覆盖选品、Listing、PPC、Review 和新品冷启动，正在写作中。你可以先看对应的 AI 提示词文章和资料模板。</p>
    </div>
    <div class="grid grid-3">
      <a class="card" href="/ai-prompts/">
        <span class="tag">AI 提示词</span>
        <h3>AI 提示词实操库</h3>
        <p>10 篇可直接复制使用的 AI 提示词，覆盖亚马逊运营核心场景。</p>
      </a>
      <a class="card" href="/resources/">
        <span class="tag">资料模板</span>
        <h3>运营资料包</h3>
        <p>Listing 自检清单、PPC 复盘表、Review 痛点分析表等配套模板。</p>
      </a>
      <a class="card" href="/articles/">
        <span class="tag">全部文章</span>
        <h3>方法论文章</h3>
        <p>选品、Listing、PPC、Review 等专题的方法论和实操指南。</p>
      </a>
    </div>

    <!-- 配套资料模板 -->
    <div class="topic-intro" style="margin-top: 40px;">
      <h2>配套资料模板</h2>
      <p>每篇案例都搭配一份可以直接套用的运营模板，把分析结论落地为运营动作。</p>
    </div>
    <div class="resource-list">
      {resources.map((r) => (
        <a class="resource-list-item" href={r.href}>
          <div class="resource-list-body">
            <h3>{r.name}</h3>
            <p>{r.desc}</p>
          </div>
          <span class="resource-list-cta">查看 →</span>
        </a>
      ))}
    </div>

    <!-- 低调承接 -->
    <div class="topic-intro cta-soft">
      <h2>不确定自己的情况属于哪一类？</h2>
      <p>如果你不确定自己遇到的问题属于哪个方向，可以先做 30 秒资料诊断，或者直接问 AI 阿岩助手。</p>
      <div class="cta-soft-actions">
        <a class="cta-primary" href="/survey/">做 30 秒资料诊断</a>
        <a class="cta-secondary" href="/ask/">问问 AI 阿岩助手</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-actions {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    flex-wrap: wrap;
  }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 14px;
    font-size: 14px;
    color: #64748b;
  }

  .hero-links a {
    color: #1368ff;
    text-decoration: none;
    font-weight: 600;
  }

  .hero-links a:hover {
    text-decoration: underline;
  }

  .hero-links-sep {
    color: #cbd5e1;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 22px;
    border-radius: 999px;
    background: #1368ff;
    color: #fff;
    font-weight: 800;
    font-size: 14px;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.1s ease;
  }

  .cta-primary:hover {
    background: #1d4ed8;
    transform: translateY(-1px);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 22px;
    border-radius: 999px;
    background: #ffffff;
    color: #1368ff;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    border: 1px solid #dce2ec;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .cta-secondary:hover {
    border-color: #1368ff;
    background: #f8faff;
  }

  .topic-intro {
    max-width: 880px;
    margin: 0 0 28px;
    padding: 24px 28px;
    background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    border: 1px solid rgba(226, 232, 240, 0.95);
    border-radius: 20px;
    box-shadow: 0 14px 40px rgba(15, 23, 42, 0.05), inset 0 1px 0 rgba(255, 255, 255, 0.95);
  }

  .topic-intro h2 {
    margin: 0 0 14px;
    font-size: 22px;
    color: #0f172a;
    letter-spacing: -0.3px;
    position: relative;
    padding-left: 12px;
  }

  .topic-intro h2::before {
    content: "";
    position: absolute;
    left: 0;
    top: 4px;
    width: 4px;
    height: 22px;
    border-radius: 999px;
    background: #1368ff;
  }

  .topic-intro p {
    margin: 0 0 12px;
    color: #475569;
    line-height: 1.85;
    font-size: 15px;
  }

  .topic-intro p:last-child {
    margin-bottom: 0;
  }

  .beginner-order-list {
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .beginner-order-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 12px;
    background: #ffffff;
    border: 1px solid #eef1f6;
    color: inherit;
  }

  .beginner-order-num {
    flex: 0 0 28px;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #94a3b8;
    color: #fff;
    font-size: 13px;
    font-weight: 800;
    flex-shrink: 0;
  }

  .beginner-order-label {
    font-weight: 700;
    color: #0f172a;
    font-size: 15px;
    margin-top: 3px;
    flex-shrink: 0;
  }

  .beginner-order-desc {
    color: #64748b;
    font-size: 13px;
    margin-top: 4px;
    display: block;
  }

  .grid {
    display: grid;
    gap: 16px;
    margin-bottom: 28px;
  }

  .grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 20px;
    border-radius: 16px;
    background: #ffffff;
    border: 1px solid #eef1f6;
    box-shadow: 0 6px 20px rgba(15, 23, 42, 0.04);
    text-decoration: none;
    color: inherit;
    transition: transform 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    border-color: #dce2ec;
    box-shadow: 0 14px 40px rgba(15, 23, 42, 0.08);
  }

  .card-pending {
    opacity: 0.65;
    cursor: default;
  }

  .card-pending:hover {
    transform: none;
    border-color: #eef1f6;
    box-shadow: 0 6px 20px rgba(15, 23, 42, 0.04);
  }

  .card .tag {
    display: inline-block;
    align-self: flex-start;
    padding: 3px 10px;
    border-radius: 999px;
    background: #eef5ff;
    color: #1368ff;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.3px;
  }

  .card .tag-pending {
    background: #f1f5f9;
    color: #94a3b8;
  }

  .card h3 {
    margin: 0;
    font-size: 15px;
    color: #0f172a;
    line-height: 1.5;
    font-weight: 700;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card p {
    margin: 0;
    font-size: 13px;
    color: #64748b;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .resource-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 28px;
  }

  .resource-list-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 20px;
    border-radius: 12px;
    background: #ffffff;
    border: 1px solid #eef1f6;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .resource-list-item:hover {
    border-color: #f4d089;
    background: #fffcf0;
  }

  .resource-list-body {
    flex: 1 1 auto;
    min-width: 0;
  }

  .resource-list-body h3 {
    margin: 0 0 4px;
    font-size: 15px;
    color: #0f172a;
    font-weight: 700;
  }

  .resource-list-body p {
    margin: 0;
    font-size: 13px;
    color: #64748b;
    line-height: 1.6;
  }

  .resource-list-cta {
    flex: 0 0 auto;
    font-size: 13px;
    font-weight: 800;
    color: #b45309;
    white-space: nowrap;
  }

  .cta-soft {
    background: linear-gradient(135deg, #f0f7ff 0%, #eef5ff 100%);
    border-color: #cfe0ff;
  }

  .cta-soft-actions {
    display: flex;
    gap: 12px;
    margin-top: 16px;
    flex-wrap: wrap;
  }

  @media (max-width: 720px) {
    .grid-3 {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      flex-direction: column;
    }

    .cta-soft-actions {
      flex-direction: column;
    }

    .resource-list-item {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
