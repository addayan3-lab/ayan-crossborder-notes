---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ResourceCenterTeaser from "../components/ResourceCenterTeaser.astro";

const allPostsForCount = await getCollection("posts", ({ data }) => !data.draft);

const topicArticleCount = allPostsForCount.reduce((acc, p) => {
  const t = p?.data?.topic;
  if (t) acc[t] = (acc[t] || 0) + 1;
  return acc;
}, {});

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const topicPaths = [
  {
    id: "keyword",
    icon: "🧭",
    title: "关键词表系列",
    desc: "从关键词来源、AI 清洗、字段设计，到 Listing 和 PPC 使用。",
    guide: {
      title: "亚马逊关键词学习路径：从找词、清洗到布局",
      href: "/articles/keyword-learning-path/",
      hint: "推荐先读"
    },
    articles: [
      { title: "如何用 AI 做亚马逊关键词表", href: "/articles/ai-keyword-table/" },
      { title: "为什么关键词表不能只看搜索量", href: "/articles/keyword-search-volume-trap/" },
      { title: "关键词从哪里来：把来源分成 4 类", href: "/articles/keyword-source-4-types/" },
      { title: "关键词清洗方法：从关键词池到可用词表", href: "/articles/keyword-cleaning-method/" }
    ],
    previews: [
    ],
    cta: { label: "看完整学习路径", href: "/articles/keyword-learning-path/" }
  },
  {
    id: "listing",
    icon: "📄",
    title: "Listing 优化系列",
    desc: "围绕标题、五点、A+、图片表达和转化逻辑。",
    guide: {
      title: "亚马逊 Listing 优化学习路径：从卖点提炼到转化表达",
      href: "/articles/listing-learning-path/",
      hint: "推荐先读"
    },
    articles: [
      { title: "AI 时代亚马逊 Listing 应该怎么写", href: "/articles/ai-listing-optimization/" },
      { title: "亚马逊 Listing 优化检查清单", href: "/articles/listing-checklist/" },
      { title: "Listing 五点写法：功能点、场景点、信任点", href: "/articles/listing-five-bullets/" }
    ],
    previews: [
      "A+ 内容的实操套路"
    ],
    cta: { label: "看完整学习路径", href: "/articles/listing-learning-path/" }
  },
  {
    id: "ppc",
    icon: "🎯",
    title: "广告 PPC 系列",
    desc: "围绕广告报表复盘、ACOS、搜索词、否词和预算分配。",
    guide: {
      title: "亚马逊 PPC 广告学习路径：从结构搭建到数据判断",
      href: "/articles/ppc-learning-path/",
      hint: "推荐先读"
    },
    articles: [
      { title: "如何用 AI 复盘亚马逊广告报表", href: "/articles/ai-ppc-report-review/" },
      { title: "新品广告第一周怎么开：预算、关键词和否词", href: "/articles/new-product-ppc-week-one/" },
      { title: "SP 广告结构：自动、精准、词组、竞品怎么分工", href: "/articles/sp-ad-structure/" }
    ],
    previews: [
      "SP / SB / SD 的分工"
    ],
    cta: { label: "看完整学习路径", href: "/articles/ppc-learning-path/" }
  },
  {
    id: "review",
    icon: "💬",
    title: "Review 分析系列",
    desc: "从评论里提炼用户痛点、卖点、场景词和产品改进机会。",
    guide: {
      title: "亚马逊 Review 分析学习路径：从评价挖掘到产品优化",
      href: "/articles/review-learning-path/",
      hint: "推荐先读"
    },
    articles: [
      { title: "如何用 AI 分析 Review 找到产品卖点", href: "/articles/ai-review-analysis/" },
      { title: "差评改 Listing：5 个步骤把负反馈变成下一版卖点", href: "/articles/negative-review-listing-fix/" },
      { title: "Review 分析矩阵：差评、好评、竞品反馈怎么用", href: "/articles/review-analysis-matrix/" }
    ],
    previews: [
      "Vine 计划配合使用"
    ],
    cta: { label: "看完整学习路径", href: "/articles/review-learning-path/" }
  },
  {
    id: "ai-search",
    icon: "🔎",
    title: "AI 搜索与消费者变化",
    desc: "理解 Amazon Rufus、Alexa for Shopping、AI 搜索和推荐变化。",
    guide: {
      title: "亚马逊 AI 搜索学习路径：从工具理解到运营应用",
      href: "/articles/ai-search-learning-path/",
      hint: "推荐先读"
    },
    articles: [
      { title: "Amazon Rufus / Alexa for Shopping 对卖家意味着什么", href: "/articles/amazon-rufus-alexa-shopping/" },
      { title: "消费者如何用 Amazon AI 搜索产品", href: "/articles/consumer-ai-search-amazon/" }
    ],
    previews: [
      "AI 搜索的意图识别",
      "图片搜索与场景化推荐"
    ],
    cta: { label: "看完整学习路径", href: "/articles/ai-search-learning-path/" }
  },
  {
    id: "tools",
    icon: "🧰",
    title: "工具模板与资料包",
    desc: "领取 AI 运营检查表、Listing Prompt、PPC 复盘表和 Review 分析模板。",
    guide: {
      title: "亚马逊工具资料学习路径：从表格、清单到实操 SOP",
      href: "/articles/tools-learning-path/",
      hint: "推荐先读"
    },
    articles: [],
    previews: [
      "运营检查表 / Listing Prompt / 复盘表",
      "后续按专题持续更新"
    ],
    cta: { label: "看完整学习路径", href: "/articles/tools-learning-path/" }
  }
];

const topicCards = [
  {
    href: "/ai-amazon/",
    icon: "🤖",
    title: "AI 运营亚马逊",
    desc: "AI 思维 + 实战方法"
  },
  {
    href: "/ppc/",
    icon: "🎯",
    title: "广告 PPC",
    desc: "投放策略与优化"
  },
  {
    href: "/listing/",
    icon: "📄",
    title: "Listing 优化",
    desc: "文案优化与转化提升"
  },
  {
    href: "/selection/",
    icon: "🛍️",
    title: "选品指南",
    desc: "选品思路与市场洞察"
  }
];

const trustItems = [
  {
    title: "实战经验",
    desc: "多年一线运营实操沉淀"
  },
  {
    title: "内容沉淀",
    desc: "系统记录与持续输出"
  },
  {
    title: "社群陪伴",
    desc: "同行交流与共同成长"
  },
  {
    title: "方法落地",
    desc: "从知识到执行的闭环"
  }
];

const resourceItems = [
  "AI 运营检查表",
  "Listing 优化 Prompt",
  "广告复盘表",
  "Review 分析模板"
];
---

<BaseLayout title="阿岩跨境笔记｜亚马逊 AI 运营实战知识站" description="阿岩跨境笔记聚焦亚马逊卖家的 AI 运营实战，覆盖选品、Listing 优化、广告 PPC、Review 分析、工具模板和运营 SOP。">
  <section class="ayan-hero">
    <div class="ayan-hero-inner">
      <div class="hero-copy">
        <div class="hello">你好，我是阿岩 👋</div>
        <h1>阿岩的亚马逊 <span>AI 运营</span><br />实战笔记</h1>
        <p class="hero-desc">
          聚焦选品、Listing、广告 PPC、Review 分析与 SOP 执行，<br />
          用 AI 提效，让运营更精准、决策更高效、增长更可持续。
        </p>

        <div class="hero-points">
          <div>
            <strong>跨境电商实战经验</strong>
            <span>多年一线运营沉淀</span>
          </div>
          <div>
            <strong>AI 提效方法论</strong>
            <span>用 AI 放大运营效能</span>
          </div>
          <div>
            <strong>可复制的 SOP</strong>
            <span>拿来即用，可落地</span>
          </div>
          <div>
            <strong>持续更新</strong>
            <span>紧跟平台与 AI 趋势</span>
          </div>
        </div>
      </div>

      <div class="hero-person-area">
        <div class="hero-glow"></div>

        <div class="hero-person">
          <img src="/images/ayan-hero.png" alt="阿岩形象照" />
        </div>

        <div class="quote-card">
          <div class="quote-mark">“</div>
          <p>AI 不会取代运营，<br />但会用 AI 的运营，<br />正在取代不会用 AI 的运营。</p>
          <span>—— 阿岩</span>
        </div>

        <div class="about-card">
          <h3>关于阿岩</h3>
          <ul>
            <li>多年亚马逊运营与教学经验</li>
            <li>专注 AI 赋能卖家效率</li>
            <li>擅长 Listing / 广告 / 选品实战</li>
            <li>陪伴卖家持续成长</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section quick-section">
    <div class="quick-grid">
      {topicCards.map((item) => (
        <a class="quick-card" href={item.href}>
          <div class="quick-icon">{item.icon}</div>
          <div>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </div>
          <span class="quick-arrow">→</span>
        </a>
      ))}
    </div>
  </section>

  <section class="home-section main-layout">
    <div class="content-main">
      <div class="block-head">
        <div>
          <h2>专题学习路径</h2>
          <p>不建议你先追工具，先按专题把问题拆开，每个环节先解决一个最小动作。</p>
        </div>
        <a href="/articles/">查看全部文章 →</a>
      </div>

      <div class="topic-grid">
        {topicPaths.map((topic) => {
          const count = topicArticleCount[topic.id] || 0;
          return (
          <article class={`topic-card topic-card-${topic.id}`}>
            <header class="topic-head">
              <div class="topic-icon">{topic.icon}</div>
              <div class="topic-head-text">
                <div class="topic-head-row">
                  <h3>{topic.title}</h3>
                  <span class="topic-count" aria-label={`本专题 ${count} 篇文章`}>
                    {count} 篇文章
                  </span>
                </div>
                <p>{topic.desc}</p>
              </div>
            </header>

            {topic.guide && (
              <a class="topic-guide" href={topic.guide.href}>
                <div class="topic-guide-hint">{topic.guide.hint}</div>
                <div class="topic-guide-title">{topic.guide.title}</div>
                <span class="topic-guide-arrow">→</span>
              </a>
            )}

            {topic.articles.length > 0 && (
              <ul class="topic-articles">
                {topic.articles.map((a) => (
                  <li>
                    <a href={a.href}>{a.title}</a>
                  </li>
                ))}
              </ul>
            )}

            <div class="topic-previews">
              <div class="topic-previews-label">后续预告</div>
              <ul>
                {topic.previews.map((p) => (
                  <li>{p}</li>
                ))}
              </ul>
            </div>

            <a class="topic-cta" href={topic.cta.href}>
              {topic.cta.label}
              <span class="topic-cta-arrow">→</span>
            </a>
          </article>
          );
        })}
      </div>

      <div class="trust-strip">
        {trustItems.map((item) => (
          <div class="trust-item">
            <div class="trust-icon">✦</div>
            <div>
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <ResourceCenterTeaser />
    </div>

    <aside class="content-side">
      <section class="side-card resource-card">
        <h2>免费领取资料包</h2>
        <ul>
          {resourceItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <div class="lead-form">
          <input placeholder="点击右侧按钮填写领取表单" />
          <a href="/lead/" target="_blank" rel="noopener noreferrer">立即领取</a>
        </div>
        <p class="small-note">资料将通过企业微信发送</p>
        <a class="resource-center-link" href="/resources/">查看全部 28 个资料包 →</a>
      </section>

      <section class="side-card course-card">
        <h2>公开课预告</h2>
        <p>AI 时代亚马逊卖家的机会与挑战</p>
        <div class="course-row">
          <span>6/12（周四）20:00 直播</span>
          <a href="/open-class/">免费预约</a>
        </div>
      </section>

      <section class="side-card about-mini">
        <div class="avatar"></div>
        <div>
          <h2>关于阿岩</h2>
          <p>专注亚马逊运营与 AI 提效实践，致力于用可复制的方法，帮助卖家实现长期稳定增长。</p>
          <a href="/about/">了解更多 →</a>
        </div>
      </section>
    </aside>
  </section>
</BaseLayout>

<style>
  .ayan-hero {
    background:
      radial-gradient(circle at 58% 50%, rgba(21, 111, 255, 0.30), transparent 26%),
      radial-gradient(circle at 88% 58%, rgba(0, 110, 255, 0.16), transparent 28%),
      linear-gradient(135deg, #030917 0%, #071a38 55%, #020917 100%);
    color: #fff;
    padding: 26px 24px 0;
    overflow: hidden;
    position: relative;
  }

  .ayan-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg, transparent 0%, rgba(45, 125, 255, 0.08) 50%, transparent 100%);
    pointer-events: none;
  }

  .ayan-hero-inner {
    max-width: 1520px;
    min-height: 300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.92fr 1.18fr;
    gap: 34px;
    align-items: end;
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    padding-bottom: 16px;
  }

  .hello {
    font-size: 20px;
    font-weight: 800;
    color: #e8f2ff;
    margin-bottom: 18px;
  }

  .hero-copy h1 {
    margin: 0;
    font-size: 48px;
    line-height: 1.08;
    letter-spacing: -1.6px;
  }

  .hero-copy h1 span {
    color: #1473ff;
  }

  .hero-desc {
    margin: 12px 0 14px;
    color: rgba(255, 255, 255, 0.84);
    font-size: 18px;
    line-height: 1.75;
  }

  .hero-points {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin: 14px 0 18px;
  }

  .hero-points strong {
    display: block;
    color: #fff;
    font-size: 14px;
    margin-bottom: 4px;
  }

  .hero-points span {
    display: block;
    color: rgba(255, 255, 255, 0.62);
    font-size: 12px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero-person-area {
    min-height: 300px;
    position: relative;
  }

  .hero-glow {
    position: absolute;
    left: -10px;
    bottom: -4px;
    width: 410px;
    height: 410px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.32), transparent 64%);
    filter: blur(12px);
    z-index: 1;
  }

  .hero-person {
    position: absolute;
    left: -36px;
    bottom: -4px;
    width: 318px;
    height: 348px;
    display: flex;
    align-items: end;
    justify-content: center;
    z-index: 3;
  }

  .hero-person img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
    display: block;
    filter: drop-shadow(0 18px 36px rgba(0, 0, 0, 0.34));
  }

  .quote-card,
  .about-card {
    position: absolute;
    right: 0;
    border: 1px solid rgba(140, 190, 255, 0.28);
    background: rgba(255, 255, 255, 0.075);
    border-radius: 16px;
    backdrop-filter: blur(14px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
    z-index: 2;
  }

  .quote-card {
    top: 34px;
    width: 280px;
    padding: 22px 26px;
  }

  .quote-mark {
    color: #7db9ff;
    font-size: 42px;
    height: 24px;
    line-height: 1;
  }

  .quote-card p {
    margin: 14px 0 10px;
    font-size: 18px;
    line-height: 1.7;
  }

  .quote-card span {
    display: block;
    text-align: right;
    color: rgba(255, 255, 255, 0.72);
  }

  .about-card {
    top: 34px;
    right: 315px;
    width: 260px;
    padding: 20px 22px;
  }

  .about-card h3 {
    margin: 0 0 14px;
  }

  .about-card ul {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .about-card li {
    margin: 10px 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 14px;
  }

  .about-card li::before {
    content: "✓";
    color: #65a7ff;
    margin-right: 8px;
  }

  .home-section {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .quick-section {
    margin-top: 8px;
  }

  .quick-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .quick-card {
    background: #fff;
    border: 1px solid #e6eaf2;
    border-radius: 14px;
    padding: 15px 16px;
    display: grid;
    grid-template-columns: 42px 1fr 24px;
    gap: 14px;
    align-items: center;
    box-shadow: 0 12px 32px rgba(15, 23, 42, 0.04);
  }

  .quick-icon {
    width: 42px;
    height: 42px;
    border-radius: 14px;
    display: grid;
    place-items: center;
    background: #eef5ff;
    font-size: 26px;
  }

  .quick-card h3 {
    margin: 0 0 4px;
    font-size: 18px;
  }

  .quick-card p {
    margin: 0;
    color: #667085;
    font-size: 13px;
  }

  .quick-arrow {
    color: #98a2b3;
    font-weight: 800;
  }

  .main-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 20px;
    padding-top: 10px;
    padding-bottom: 40px;
  }

  .block-head {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: end;
    margin-bottom: 14px;
  }

  .block-head h2 {
    margin: 0 0 6px;
    font-size: 26px;
  }

  .block-head p {
    margin: 0;
    color: #667085;
  }

  .block-head a {
    color: #1368ff;
    font-weight: 700;
    white-space: nowrap;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .article-card {
    background: #fff;
    border: 1px solid #e6eaf2;
    border-radius: 16px;
    padding: 12px;
    display: grid;
    grid-template-columns: 142px 1fr;
    gap: 14px;
    min-height: 166px;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
  }

  .article-thumb {
    width: 142px;
    min-height: 142px;
    height: 142px;
    border-radius: 12px;
    background:
      radial-gradient(circle at 40% 30%, rgba(44, 160, 255, 0.6), transparent 28%),
      linear-gradient(135deg, #06152f, #0b3a82);
    position: relative;
    overflow: hidden;
    background-size: cover;
    background-position: center;
  }

  .article-thumb span {
    position: absolute;
    left: 10px;
    top: 10px;
    padding: 5px 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.16);
    color: #fff;
    font-size: 11px;
    font-weight: 800;
  }

  .article-tag {
    display: inline-flex;
    padding: 4px 8px;
    border-radius: 999px;
    background: #eaf2ff;
    color: #1368ff;
    font-size: 12px;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .article-card h3 {
    margin: 0 0 8px;
    font-size: 18px;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card p {
    margin: 0 0 10px;
    color: #667085;
    line-height: 1.55;
    font-size: 13px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-meta {
    display: flex;
    justify-content: space-between;
    color: #8b95a5;
    font-size: 13px;
  }

  .trust-strip {
    margin-top: 18px;
