---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getPostsBySlot } from "../lib/content-orchestration";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const slotArticles = {
  "ai-prompt": getPostsBySlot(allPosts, "ai-prompt"),
  "resource-tutorial": getPostsBySlot(allPosts, "resource-tutorial"),
  "beginner-start": getPostsBySlot(allPosts, "beginner-start"),
};

const topicPaths = [
  {
    id: "keyword",
    icon: "🧭",
    title: "关键词搜索系列",
    desc: "从关键词来源、AI 清洗到字段设计，掌握完整的关键词运营链路。",
    points: [
      "关键词来源与清洗方法",
      "关键词字段设计与布局",
      "关键词在 Listing 和 PPC 中的使用"
    ],
    cta: { label: "查看学习路径", href: "/articles/keyword-learning-path/" }
  },
  {
    id: "listing",
    icon: "📄",
    title: "Listing 优化系列",
    desc: "围绕标题、五点、A+ 和图片表达，系统提升 Listing 转化力。",
    points: [
      "亚马逊 Listing 核心要素拆解",
      "用户卖点提炼与表达方法",
      "A+ 内容与转化率优化"
    ],
    cta: { label: "查看学习路径", href: "/articles/listing-learning-path/" }
  },
  {
    id: "ppc",
    icon: "🎯",
    title: "广告 PPC 系列",
    desc: "从广告结构搭建到数据复盘，学会用数据驱动广告优化。",
    points: [
      "SP / SB / SD 广告结构选择",
      "ACOS 分析与搜索词优化",
      "否词策略与预算分配逻辑"
    ],
    cta: { label: "查看学习路径", href: "/articles/ppc-learning-path/" }
  },
  {
    id: "review",
    icon: "💬",
    title: "Review 分析系列",
    desc: "从评论中挖掘用户痛点、卖点和产品改进机会。",
    points: [
      "Review 分析方法与框架",
      "从差评到产品改进的闭环",
      "Vine 计划与评价管理策略"
    ],
    cta: { label: "查看学习路径", href: "/articles/review-learning-path/" }
  }
];

const trustItems = [
  { title: "实战干货", desc: "多年一线运营实操沉淀" },
  { title: "持续更新", desc: "紧跟平台变化与 AI 提效" },
  { title: "可落地", desc: "每篇文章都有可执行 SOP" },
  { title: "社群陪伴", desc: "同行交流与共同成长" }
];
---

<BaseLayout title="阿岩跨境笔记｜亚马逊 AI 运营实战知识站" description="阿岩跨境笔记聚焦亚马逊卖家的 AI 运营实战，覆盖选品、Listing 优化、广告 PPC、Review 分析、工具模板和运营 SOP。">

  <!-- Hero -->
  <section class="ayan-hero">
    <div class="ayan-hero-inner">
      <div class="hero-copy">
        <div class="hello">👋 你好，我是阿岩</div>
        <h1>阿岩的亚马逊 <span>AI 运营</span><br />实战笔记</h1>
        <p class="hero-desc">
          聚焦选品、Listing、广告 PPC、Review 分析与 SOP 执行，用 AI 提效，让运营更精准。
        </p>
        <div class="hero-metrics">
          <div class="hero-metric">
            <span class="hero-metric-num">56</span>
            <span class="hero-metric-label">实操文章</span>
          </div>
          <div class="hero-metric-dot"></div>
          <div class="hero-metric">
            <span class="hero-metric-num">28</span>
            <span class="hero-metric-label">资料模板</span>
          </div>
          <div class="hero-metric-dot"></div>
          <div class="hero-metric">
            <span class="hero-metric-num">3</span>
            <span class="hero-metric-label">系列公开课</span>
          </div>
        </div>
        <div class="hero-actions">
          <a class="hero-btn hero-btn-primary" href="/ai-amazon/">开始学习</a>
          <a class="hero-btn hero-btn-secondary" href="/resources/">免费领资料</a>
        </div>
      </div>

      <div class="hero-visual-area">
        <div class="hero-person-wrap">
          <div class="hero-glow-bg"></div>
          <div class="hero-person">
            <img src="/images/ayan-hero.png" alt="阿岩形象照" />
          </div>
        </div>
        <div class="quote-card">
          <div class="quote-mark">"</div>
          <p>AI 不会取代运营，<br />但会用 AI 的运营，<br />正在取代不会用 AI 的运营。</p>
          <span>—— 阿岩</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 3 Entry Cards -->
  <section class="home-section entry-trio-section">
    <div class="entry-trio">
      <a class="entry-card entry-card-ask" href="/ask/">
        <div class="entry-card-icon entry-card-icon-ask">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 5.3 18.5l3.7 1-1-3.7A10 10 0 0 0 12 2z"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
        </div>
        <div class="entry-card-title">问问 AI 阿岩助手</div>
        <div class="entry-card-desc">输入你的亚马逊运营问题，智能推荐对应文章、模板和公开课。</div>
        <span class="entry-card-btn entry-card-btn-ask">试试提问</span>
      </a>
      <a class="entry-card entry-card-survey" href="/survey/">
        <div class="entry-card-icon entry-card-icon-survey">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg>
        </div>
        <div class="entry-card-title">做 30 秒资料诊断</div>
        <div class="entry-card-desc">根据你的运营阶段和水平，推荐最适合你的学习资料路径。</div>
        <span class="entry-card-btn entry-card-btn-survey">开始诊断</span>
      </a>
      <a class="entry-card entry-card-cases" href="/cases/">
        <div class="entry-card-icon entry-card-icon-cases">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
        </div>
        <div class="entry-card-title">实操案例库</div>
        <div class="entry-card-desc">用脱敏案例拆解选品、Listing、PPC 和新品冷启动实战。</div>
        <span class="entry-card-btn entry-card-btn-cases">查看案例</span>
      </a>
    </div>
  </section>

  <!-- AI Prompt Zone -->
  {
    slotArticles["ai-prompt"].length > 0 && (
    <section class="home-section prompt-section">
      <div class="prompt-section-head">
        <h2>AI 提示词专区</h2>
        <a href="/ai-prompts/">查看全部提示词 →</a>
      </div>
      <div class="prompt-pills">
        {slotArticles["ai-prompt"].slice(0, 5).map((a) => (
          <a class="prompt-pill" href={a.href}>
            {a.title}
            <span class="pill-arrow">→</span>
          </a>
        ))}
      </div>
    </section>
    )
  }

  <!-- Learning Paths -->
  <section class="home-section paths-section">
    <div class="paths-head">
      <div>
        <h2>专题学习路径</h2>
        <p class="paths-desc">从关键词到广告，系统掌握亚马逊运营核心技能。</p>
      </div>
      <a href="/articles/">查看全部文章 →</a>
    </div>
    <div class="paths-grid">
      {topicPaths.map((topic) => (
      <article class={`path-card path-card-${topic.id}`}>
        <div class="path-icon-wrap">
          <div class="path-icon">{topic.icon}</div>
        </div>
        <h3>{topic.title}</h3>
        <ul class="path-points">
          {topic.points.map((pt) => (
            <li>{pt}</li>
          ))}
        </ul>
        <a class="path-cta" href={topic.cta.href}>
          {topic.cta.label}
          <span>→</span>
        </a>
      </article>
      ))}
    </div>
  </section>

  <!-- Resource Area -->
  <section class="home-section res-section">
    <div class="res-head">
      <div>
        <h2>选品与运营资源区</h2>
        <p class="res-desc">免费模板工具包，拿来就能用。</p>
      </div>
      <a href="/resources/">查看全部资料包 →</a>
    </div>
    <div class="res-grid">
      <a class="res-card res-card-blue" href="/resources/?tab=keyword">
        <div class="res-card-icon res-card-icon-1">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <h3>关键词深度研究模板包</h3>
        <p>关键词清洗表、来源分类、字段设计模板</p>
        <span class="res-card-btn">免费领取</span>
      </a>
      <a class="res-card res-card-green" href="/resources/?tab=listing">
        <div class="res-card-icon res-card-icon-2">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg>
        </div>
        <h3>Listing 优化检查清单</h3>
        <p>标题、五点、A+、图片自查完整清单</p>
        <span class="res-card-btn">免费领取</span>
      </a>
      <a class="res-card res-card-orange" href="/resources/?tab=ppc">
        <div class="res-card-icon res-card-icon-3">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        </div>
        <h3>PPC 投放复盘工具包</h3>
        <p>广告复盘表、ACOS 分析框架、否词策略表</p>
        <span class="res-card-btn">免费领取</span>
      </a>
      <a class="res-card res-card-purple" href="/resources/?tab=review">
        <div class="res-card-icon res-card-icon-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3>Review 运营分析工具包</h3>
        <p>痛点分析矩阵、卖点提炼模板、评价管理表</p>
        <span class="res-card-btn">免费领取</span>
      </a>
    </div>
  </section>

  <!-- Public Lessons -->
  <section class="home-section oc-section">
    <div class="open-class-entry">
      <div class="open-class-entry-head">
        <div>
          <h2>公开课学习入口</h2>
          <p>把关键词、Listing、广告、Review 和 AI 工具串成实操公开课。</p>
        </div>
        <a class="open-class-entry-cta" href="/open-class/">查看全部公开课 →</a>
      </div>
      <div class="open-class-grid">
        <a class="oc-card oc-card-blue" href="/open-class/keyword-to-listing/">
          <span class="oc-card-status oc-status-available">可预约</span>
          <h3>关键词到 Listing 的实操课</h3>
          <p class="oc-card-summary">掌握高转化关键词挖掘与 Listing 优化链路</p>
          <span class="oc-card-meta">05/24（周五）20:00</span>
          <span class="oc-card-btn oc-card-btn-blue">立即预约</span>
        </a>
        <a class="oc-card oc-card-green" href="/open-class/ppc-week-one/">
          <span class="oc-card-status oc-status-available">可预约</span>
          <h3>新品 PPC 首周广告结构课</h3>
          <p class="oc-card-summary">新品第一周广告怎么开、预算怎么分</p>
          <span class="oc-card-meta">06/07（周五）20:00</span>
          <span class="oc-card-btn oc-card-btn-green">立即预约</span>
        </a>
        <a class="oc-card oc-card-orange" href="/open-class/review-to-selection/">
          <span class="oc-card-status oc-status-live">回放可看</span>
          <h3>Review 反推选品与页面优化课</h3>
          <p class="oc-card-summary">从差评和好评里找产品改进方向</p>
          <span class="oc-card-meta">已结束 · 回放可看</span>
          <span class="oc-card-btn oc-card-btn-orange">观看回放</span>
        </a>
        <a class="oc-card oc-card-purple" href="/open-class/listing-conversion-check/">
          <span class="oc-card-status oc-status-available">可预约</span>
          <h3>Listing 自检与转化表达课</h3>
          <p class="oc-card-summary">用一张自检清单检查关键词、卖点和图片表达</p>
          <span class="oc-card-meta">06/21（周六）20:00</span>
          <span class="oc-card-btn oc-card-btn-purple">立即预约</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="home-section trust-section">
    <div class="trust-strip">
      {trustItems.map((item) => (
        <div class="trust-item">
          <div class="trust-icon-circle">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <div class="trust-item-title">{item.title}</div>
            <div class="trust-item-desc">{item.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Global Body ===== */
  :global(body) {
    background: linear-gradient(180deg, #f6f9fd 0%, #edf3fa 100%);
  }

  /* ===== Hero ===== */
  .ayan-hero {
    background:
      linear-gradient(90deg, rgba(3,13,31,0.88) 0%, rgba(7,25,58,0.65) 48%, rgba(3,13,31,0.82) 100%),
      url('/images/home/ayan-home-hero-tech-bg.png') center center / cover no-repeat;
    color: #fff;
    padding: 32px 24px 0;
    overflow: hidden;
    position: relative;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .ayan-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(255,255,255,0.010) 60px, rgba(255,255,255,0.010) 61px),
      repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(255,255,255,0.010) 60px, rgba(255,255,255,0.010) 61px);
    pointer-events: none;
    z-index: 0;
  }

  .ayan-hero-inner {
    max-width: 1520px;
    min-height: 360px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.95fr 1.15fr;
    gap: 20px;
    align-items: end;
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    padding-bottom: 24px;
    position: relative;
    z-index: 2;
  }

  .hello {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 16px;
    font-weight: 700;
    color: #b8d6ff;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.10);
    padding: 6px 16px 6px 14px;
    border-radius: 999px;
    margin-bottom: 20px;
  }

  .hero-copy h1 {
    margin: 0;
    font-size: 56px;
    line-height: 1.06;
    letter-spacing: -2px;
    text-shadow: 0 16px 56px rgba(0,0,0,0.28);
  }

  .hero-copy h1 span {
    background: linear-gradient(135deg, #7ab7ff, #2d7aff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    margin: 14px 0 0;
    color: rgba(255,255,255,0.78);
    font-size: 17px;
    line-height: 1.75;
    max-width: 560px;
  }

  .hero-metrics {
    display: flex;
    align-items: center;
    gap: 18px;
    margin: 22px 0 26px;
  }

  .hero-metric {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-metric-num {
    font-size: 24px;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.3px;
  }

  .hero-metric-label {
    font-size: 12px;
    color: rgba(255,255,255,0.50);
    font-weight: 600;
  }

  .hero-metric-dot {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: rgba(255,255,255,0.30);
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 50px;
    padding: 0 32px;
    border-radius: 14px;
    font-weight: 900;
    font-size: 16px;
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .hero-btn-primary {
    background: linear-gradient(135deg, #2d7aff, #1560f0);
    color: #fff;
    box-shadow: 0 14px 36px rgba(21, 96, 240, 0.34);
  }

  .hero-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 46px rgba(21, 96, 240, 0.46);
  }

  .hero-btn-secondary {
    background: rgba(255,255,255,0.08);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.18);
  }

  .hero-btn-secondary:hover {
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.28);
    transform: translateY(-2px);
  }

  /* ===== Hero Visual Area ===== */
  .hero-visual-area {
    min-height: 340px;
    position: relative;
  }

  .hero-person-wrap {
    position: absolute;
    left: -24px;
    bottom: 0;
    width: 380px;
    height: 400px;
    z-index: 2;
  }

  .hero-glow-bg {
    position: absolute;
    left: -20px;
    bottom: 0;
    width: 360px;
    height: 360px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.15), transparent 60%);
    filter: blur(16px);
    z-index: 1;
  }

  .hero-person {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: end;
    justify-content: center;
    z-index: 2;
  }

  .hero-person img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
    display: block;
    filter: drop-shadow(0 20px 42px rgba(0,0,0,0.36));
  }

  .quote-card {
    position: absolute;
    top: 24px;
    right: 0;
    width: 270px;
    padding: 22px 24px;
    border: 1px solid rgba(147, 197, 253, 0.18);
    background: rgba(255,255,255,0.06);
    border-radius: 18px;
    backdrop-filter: blur(16px);
    box-shadow: 0 32px 80px rgba(0,0,0,0.28), inset 0 1px 0 rgba(255,255,255,0.08);
    z-index: 3;
  }

  .quote-mark {
    color: rgba(125, 185, 255, 0.55);
    font-size: 44px;
    height: 18px;
    line-height: 1;
    font-family: Georgia, serif;
  }

  .quote-card p {
    margin: 12px 0 12px;
    font-size: 16px;
    line-height: 1.75;
    color: rgba(255,255,255,0.86);
  }

  .quote-card span {
    display: block;
    text-align: right;
    color: rgba(255,255,255,0.50);
    font-size: 13px;
    font-weight: 600;
  }

  /* ===== Common Section ===== */
  .home-section {
    max-width: 1520px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .entry-trio-section { margin-top: 28px; }
  .prompt-section { margin-top: 28px; }
  .paths-section { margin-top: 36px; }
  .res-section { margin-top: 36px; }
  .oc-section { margin-top: 36px; }
  .trust-section { margin-top: 36px; }

  /* ===== 3 Entry Cards ===== */
  .entry-trio {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .entry-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    padding: 24px 26px 22px;
