---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import RelatedArticles from "../../components/RelatedArticles.astro";
import NextUp from "../../components/NextUp.astro";
import BackToLearningPath from "../../components/BackToLearningPath.astro";
import LearningPathStats from "../../components/LearningPathStats.astro";
import ArticleNavHints from "../../components/ArticleNavHints.astro";
import manifest from "../../data/image-manifest.json";

const imageAltMap = Object.fromEntries(
  manifest.map((item) => [item.path, item.alt])
);

export async function getStaticPaths() {
  const allPosts = await getCollection("posts", ({ data }) => !data.draft);

  return allPosts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts }
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

function formatDate(date) {
  return new Date(date).toLocaleDateString("zh-CN", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit"
  });
}

function slugify(text) {
  return String(text)
    .trim()
    .replace(/[^\p{L}\p{N}\s-]/gu, "")
    .replace(/\s+/g, "-")
    .toLowerCase();
}

function stripEmoji(text) {
  return String(text).replace(/[^\p{L}\p{N}\p{P}\s]/gu, "").trim();
}

const rawBody = post.body || "";
const headings = [...rawBody.matchAll(/^##\s+(.+)$/gm)].map((match) => {
  const text = match[1].trim();
  return {
    text,
    id: slugify(text)
  };
});

// AYAN_ARTICLE_JSONLD_FRONTMATTER_START
const ayanArticleSiteUrl = "https://amz.hao1234.top";
const ayanArticleUrl = new URL(Astro.url.pathname, ayanArticleSiteUrl).toString();
const ayanArticleImage = post.data.image
  ? ayanArticleSiteUrl + post.data.image
  : ayanArticleSiteUrl + "/images/og-default.svg";

const ayanArticleStructuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "url": ayanArticleUrl,
  "mainEntityOfPage": ayanArticleUrl,
  "datePublished": new Date(post.data.pubDate).toISOString(),
  "dateModified": new Date(post.data.pubDate).toISOString(),
  "inLanguage": "zh-CN",
  "author": {
    "@type": "Person",
    "name": "阿岩"
  },
  "publisher": {
    "@type": "Organization",
    "name": "阿岩跨境笔记",
    "logo": {
      "@type": "ImageObject",
      "url": ayanArticleImage
    }
  },
  "image": [
    ayanArticleImage
  ]
};
// AYAN_ARTICLE_JSONLD_FRONTMATTER_END

// AYAN_BREADCRUMB_JSONLD_START
const ayanTopicLandingMap = {
  listing: { href: "/listing/", name: "Listing 优化" },
  ppc: { href: "/ppc/", name: "广告 PPC" },
  "ai-search": { href: "/ai-amazon/", name: "AI 运营亚马逊" },
  selection: { href: "/selection/", name: "选品指南" },
  tools: { href: "/tools/", name: "工具模板" }
};

const ayanBreadcrumbItems = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "首页",
    "item": ayanArticleSiteUrl + "/"
  }
];

const ayanTopic = post.data.topic;
if (ayanTopic && ayanTopicLandingMap[ayanTopic]) {
  const landing = ayanTopicLandingMap[ayanTopic];
  ayanBreadcrumbItems.push({
    "@type": "ListItem",
    "position": ayanBreadcrumbItems.length + 1,
    "name": landing.name,
    "item": ayanArticleSiteUrl + landing.href
  });
}

ayanBreadcrumbItems.push({
  "@type": "ListItem",
  "position": ayanBreadcrumbItems.length + 1,
  "name": post.data.title,
  "item": ayanArticleUrl
});

const ayanBreadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": ayanBreadcrumbItems
};
// AYAN_BREADCRUMB_JSONLD_END
---

<BaseLayout title={post.data.title} description={post.data.description} image={ayanArticleImage}>
  <!-- AYAN_ARTICLE_JSONLD_START -->
  <script type="application/ld+json" set:html={JSON.stringify(ayanArticleStructuredData)}></script>
  <!-- AYAN_ARTICLE_JSONLD_END -->
  <!-- AYAN_BREADCRUMB_JSONLD_START -->
  <script type="application/ld+json" set:html={JSON.stringify(ayanBreadcrumbStructuredData)}></script>
  <!-- AYAN_BREADCRUMB_JSONLD_END -->
  <main class="article-page">
    <div class="article-shell">
      <aside class="article-toc">
        <a class="back-link" href="/articles/">← 返回全部文章</a>

        {headings.length > 0 && (
          <nav class="toc-card" aria-label="文章目录">
            <div class="toc-title">文章目录</div>
            <ol>
              {headings.map((heading) => (
                <li>
                  <a href={`#${heading.id}`}>{stripEmoji(heading.text)}</a>
                </li>
              ))}
            </ol>
          </nav>
        )}

        <section class="toc-cta">
          <div class="toc-cta-title">免费资料包</div>
          <p>领取 AI 运营检查表、Listing Prompt、广告复盘表。</p>
          <a href="/lead/" target="_blank" rel="noopener noreferrer">立即领取</a>
        </section>
      </aside>

      <article class="article-card-detail">
        <header class="article-header">
          <div class="article-category">{post.data.category}</div>
          <h1>{post.data.title}</h1>
          <p class="article-desc">{post.data.description}</p>
          {post.data.image && post.data.image !== "/images/og-default.svg" && (
            <div class="article-cover">
              <img src={post.data.image} alt={imageAltMap[post.data.image] || "文章封面图"} loading="lazy" />
            </div>
          )}
          <div class="article-meta">
            <span>{formatDate(post.data.pubDate)}</span>
            <span>阿岩跨境笔记</span>
          </div>
          <LearningPathStats post={post} allPosts={allPosts} />
        </header>

        {(post.data.topic || post.data.stage || post.data.intent) && (
          <div class="article-pagefind-meta" aria-hidden="true">
            {post.data.topic && <span data-pagefind-filter="topic" data-pagefind-meta="topic">{post.data.topic}</span>}
            {post.data.stage && <span data-pagefind-filter="stage" data-pagefind-meta="stage">{post.data.stage}</span>}
            {post.data.intent && <span data-pagefind-filter="intent" data-pagefind-meta="intent">{post.data.intent}</span>}
          </div>
        )}

        <section class="article-content" id="article-content">
          <Content />
        </section>

        <section class="article-bottom-cta">
          <div>
            <h2>想把 AI 真正用进亚马逊运营？</h2>
            <p>先从一张检查表、一套 Prompt 和一份广告复盘模板开始，把方法落到每天的运营动作里。</p>
          </div>
          <a href="/lead/" target="_blank" rel="noopener noreferrer">领取 AI 运营资料包</a>
        </section>

        <section class="article-disclaimer">
          <strong>说明：</strong>
          本文为亚马逊运营教学与方法整理，不构成平台政策、法律、税务或投资建议。具体操作请结合你的类目、账号状态、产品数据和亚马逊最新规则人工判断。
        </section>

        <ArticleNavHints post={post} allPosts={allPosts} />
        <RelatedArticles post={post} allPosts={allPosts} max={4} />
        <NextUp post={post} allPosts={allPosts} />
        <BackToLearningPath post={post} />
      </article>
    </div>
  </main>

  <script>
    function slugify(text) {
      return String(text)
        .trim()
        .replace(/[^\p{L}\p{N}\s-]/gu, "")
        .replace(/\s+/g, "-")
        .toLowerCase();
    }

    const content = document.querySelector("#article-content");
    if (content) {
      const h2s = content.querySelectorAll("h2");
      h2s.forEach((h2) => {
        if (!h2.id) {
          h2.id = slugify(h2.textContent || "");
        }
      });
    }
  </script>
</BaseLayout>

<style is:global>
  .article-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at 18% 10%, rgba(19, 104, 255, 0.06), transparent 25%),
      linear-gradient(180deg, #f6f9fd 0%, #eef3fa 100%);
    padding: 44px 24px 72px;
  }

  .article-shell {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    gap: 28px;
    align-items: start;
  }

  .article-toc {
    position: sticky;
    top: 92px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    color: #1368ff;
    font-weight: 900;
    font-size: 14px;
  }

  .toc-card,
  .toc-cta {
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(226, 232, 240, 0.95);
    border-radius: 20px;
    box-shadow:
      0 18px 50px rgba(15, 23, 42, 0.06),
      inset 0 1px 0 rgba(255,255,255,0.9);
    padding: 18px;
  }

  .toc-title {
    font-size: 16px;
    font-weight: 900;
    color: #0f172a;
    margin-bottom: 12px;
  }

  .toc-card ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .toc-card a {
    display: block;
    color: #64748b;
    font-size: 13px;
    line-height: 1.5;
    padding-left: 10px;
    border-left: 2px solid #e2e8f0;
  }

  .toc-card a:hover {
    color: #1368ff;
    border-left-color: #1368ff;
  }

  .toc-cta-title {
    font-size: 17px;
    font-weight: 900;
    color: #0f172a;
    margin-bottom: 8px;
  }

  .toc-cta p {
    margin: 0 0 14px;
    color: #64748b;
    font-size: 13px;
    line-height: 1.7;
  }

  .toc-cta a {
    display: grid;
    place-items: center;
    height: 38px;
    border-radius: 11px;
    background: #1368ff;
    color: #fff;
    font-weight: 900;
  }

  .article-card-detail {
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(226, 232, 240, 0.96);
    border-radius: 28px;
    box-shadow:
      0 24px 80px rgba(15, 23, 42, 0.08),
      inset 0 1px 0 rgba(255,255,255,0.95);
    overflow: hidden;
  }

  .article-header {
    padding: 42px 52px 30px;
    background:
      radial-gradient(circle at 85% 0%, rgba(19, 104, 255, 0.09), transparent 28%),
      linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    border-bottom: 1px solid #eef2f7;
  }

  .article-cover {
    margin: 20px 0 0;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(226, 232, 240, 0.95);
  }

  .article-cover img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1200 / 630;
    object-fit: cover;
  }

  .article-category {
    display: inline-flex;
    align-items: center;
    height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: #eef5ff;
    color: #1368ff;
    border: 1px solid #dceaff;
    font-size: 13px;
    font-weight: 900;
    margin-bottom: 16px;
  }

  .article-header h1 {
    max-width: 820px;
    margin: 0;
    color: #0f172a;
    font-size: 42px;
    line-height: 1.18;
    letter-spacing: -1.1px;
  }

  .article-desc {
    max-width: 760px;
    margin: 18px 0 0;
    color: #64748b;
    font-size: 18px;
    line-height: 1.75;
  }

  .article-meta {
    margin-top: 18px;
    display: flex;
    gap: 16px;
    color: #94a3b8;
    font-size: 14px;
  }

  .article-content {
    padding: 38px 52px 48px;
    max-width: 880px;
    box-sizing: border-box;
  }

  .article-content h1 {
    display: none;
  }

  .article-content h2 {
    scroll-margin-top: 96px;
    margin: 46px 0 18px;
    color: #0f172a;
    font-size: 30px;
    line-height: 1.35;
    letter-spacing: -0.4px;
    position: relative;
    padding-left: 14px;
  }

  .article-content h2::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 5px;
    height: 28px;
    border-radius: 999px;
    background: #1368ff;
    box-shadow: 0 0 18px rgba(19, 104, 255, 0.34);
  }

  .article-content h3 {
    margin: 30px 0 14px;
    color: #102033;
    font-size: 23px;
    line-height: 1.45;
  }

  .article-content p {
    color: #334155;
    font-size: 17px;
    line-height: 2.05;
    margin: 14px 0;
  }

  .article-content ul,
  .article-content ol {
    margin: 16px 0 22px;
    padding-left: 24px;
    color: #334155;
  }

  .article-content li {
    font-size: 17px;
    line-height: 1.95;
    margin: 4px 0;
  }

  .article-content img {
    width: 100%;
    max-width: 100%;
    height: auto;
    display: block;
    border-radius: 22px;
    box-shadow: 0 20px 56px rgba(15, 23, 42, 0.13);
    border: 1px solid rgba(226, 232, 240, 0.95);
    margin: 34px auto 38px;
    object-fit: contain;
  }

  .article-content strong {
    color: #0f172a;
    font-weight: 900;
    background: linear-gradient(to top, rgba(19, 104, 255, 0.07), transparent 55%);
    padding: 0 2px;
  }

  .article-content blockquote {
    margin: 28px 0;
    padding: 20px 24px;
    border-radius: 16px;
    background: #f0f7ff;
    border-left: 4px solid #1368ff;
    color: #1e3a5f;
    font-size: 16px;
    line-height: 1.85;
  }

  .article-content blockquote p {
    margin: 0;
    color: inherit;
    font-size: inherit;
  }

  .article-content .article-callout {
    margin: 28px 0;
    padding: 20px 24px;
    border-radius: 16px;
    border: 1px solid;
    font-size: 16px;
    line-height: 1.85;
    box-sizing: border-box;
  }

  .article-content .article-callout p {
    margin: 0;
    color: inherit;
    font-size: inherit;
  }

  .article-content .article-callout strong {
    background: none;
    padding: 0;
  }

  .article-content .article-callout-blue {
    background: #f0f5ff;
    border-color: rgba(19, 104, 255, 0.15);
    border-left: 4px solid #1368ff;
    color: #1e3a5f;
  }

  .article-content .article-callout-yellow {
    background: #fffcf0;
    border-color: rgba(217, 119, 6, 0.15);
    border-left: 4px solid #d97706;
    color: #5c3d0c;
  }

  .article-content .article-callout-green {
    background: #f0fdf4;
    border-color: rgba(22, 163, 74, 0.15);
    border-left: 4px solid #16a34a;
    color: #14532d;
  }

  .article-content .article-callout-red {
    background: #fef2f2;
    border-color: rgba(220, 38, 38, 0.12);
    border-left: 4px solid #dc2626;
    color: #5c1010;
  }

  .article-content p:first-of-type {
    font-size: 18px;
    color: #1e293b;
    line-height: 2.1;
  }

  .article-content code {
    background: #eef5ff;
    color: #0f4fc7;
    padding: 2px 6px;
    border-radius: 7px;
    font-size: 0.92em;
  }

  .article-content pre {
    overflow: auto;
    border-radius: 18px;
    padding: 20px;
    background: #06152f;
    color: #dbeafe;
    margin: 24px 0;
  }

  .article-content pre code {
    background: transparent;
    color: inherit;
    padding: 0;
  }

  .article-content hr {
    border: 0;
    border-top: 1px solid #e2e8f0;
    margin: 42px 0;
  }

  .auto-article-image {
    width: 100%;
    max-width: 100%;
    margin: 34px auto 38px;
    padding: 0;
    box-sizing: border-box;
  }

  .auto-article-image img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    border-radius: 22px;
    box-shadow: 0 20px 56px rgba(15, 23, 42, 0.13);
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-sizing: border-box;
  }

  .auto-article-image figcaption {
    margin-top: 10px;
    text-align: center;
    color: #8b95a5;
    font-size: 13px;
    line-height: 1.6;
  }

  .article-bottom-cta {
    margin: 4px 52px 0;
    padding: 28px;
    border-radius: 24px;
    background:
      radial-gradient(circle at 88% 0%, rgba(19, 104, 255, 0.16), transparent 30%),
      linear-gradient(135deg, #06152f, #0b3473);
    color: #fff;
    display: grid;
    grid-template-columns: 1fr 180px;
    gap: 24px;
    align-items: center;
  }

  .article-bottom-cta h2 {
    margin: 0 0 10px;
    font-size: 26px;
    line-height: 1.35;
  }

  .article-bottom-cta p {
    margin: 0;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.8;
  }

  .article-bottom-cta a {
    height: 46px;
    border-radius: 13px;
    background: #ffffff;
    color: #1368ff;
    display: grid;
    place-items: center;
    font-weight: 900;
  }

  .article-disclaimer {
    margin: 22px 52px 44px;
    padding: 16px 18px;
    border-radius: 16px;
    background: #f8fafc;
    color: #64748b;
    font-size: 13px;
    line-height: 1.8;
    border: 1px solid #e2e8f0;
  }

  .article-pagefind-meta {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .article-pagefind-meta span {
    display: block;
  }

  .learning-path-stats {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(19, 104, 255, 0.08);
    border: 1px solid rgba(19, 104, 255, 0.18);
    color: #1e3a5f;
    font-size: 13px;
    line-height: 1.5;
  }

  .learning-path-stats-tag {
    display: inline-flex;
    align-items: center;
    height: 22px;
    padding: 0 9px;
    border-radius: 999px;
    background: #1368ff;
    color: #fff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.4px;
  }

  .learning-path-stats-text {
    color: #1e3a5f;
  }

  .learning-path-stats-text strong {
    color: #1368ff;
    font-weight: 900;
    margin: 0 2px;
  }

  .related-articles {
    margin: 30px 52px 0;
    padding: 26px 28px;
    border-radius: 22px;
    background:
      radial-gradient(circle at 92% 0%, rgba(19, 104, 255, 0.06), transparent 28%),
      linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow:
      0 16px 44px rgba(15, 23, 42, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
  }

  .related-articles-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
  }

  .related-articles-title {
    font-size: 18px;
    font-weight: 900;
    color: #0f172a;
    letter-spacing: -0.2px;
    position: relative;
    padding-left: 12px;
  }

  .related-articles-title::before {
    content: "";
    position: absolute;
    left: 0;
    top: 4px;
    width: 4px;
    height: 18px;
    border-radius: 999px;
    background: #1368ff;
  }

  .related-articles-hint {
    font-size: 12px;
    color: #64748b;
    font-weight: 700;
  }

  .related-articles-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .related-article-card {
    display: block;
    padding: 14px 16px;
    border-radius: 14px;
    background: #f7faff;
    border: 1px solid #e2ecfb;
    color: inherit;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .related-article-card:hover {
    transform: translateY(-1px);
    border-color: rgba(19, 104, 255, 0.32);
    background: #eef5ff;
    box-shadow: 0 12px 28px rgba(19, 104, 255, 0.10);
  }

  .related-article-topic {
    display: inline-flex;
    align-items: center;
    height: 22px;
    padding: 0 9px;
    border-radius: 999px;
    background: #ffffff;
    color: #1368ff;
    border: 1px solid #cfe0ff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.2px;
    margin-bottom: 8px;
  }

  .related-article-title {
    font-size: 15px;
    font-weight: 800;
    color: #0f172a;
    line-height: 1.45;
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-article-desc {
    margin: 0;
    color: #64748b;
    font-size: 13px;
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .next-up {
    margin: 18px 52px 0;
    padding: 0;
  }

  .next-up-label {
    font-size: 12px;
    color: #94a3b8;
    font-weight: 800;
    letter-spacing: 0.4px;
    margin-bottom: 10px;
  }

  .next-up-card {
    display: flex;
    align-items: center;
