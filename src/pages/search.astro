---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="站内搜索｜阿岩跨境笔记" description="搜索阿岩跨境笔记中的亚马逊 AI 运营、PPC、Listing、选品和工具模板内容。">
  <main class="search-page">
    <section class="search-hero">
      <div class="search-kicker">Search</div>
      <h1>站内搜索</h1>
      <p>搜索亚马逊 AI 运营、广告 PPC、Listing 优化、选品指南和工具模板。</p>
    </section>

    <section class="search-card">
      <div class="search-box">
        <input id="ayan-search-input" type="search" placeholder="搜索 AI 运营、PPC、Listing、选品、Review……" autocomplete="off" />
        <button id="ayan-search-button" type="button">搜索</button>
      </div>

      <div class="search-tips">
        <span>热门：</span>
        <button type="button" data-keyword="AI 运营">AI 运营</button>
        <button type="button" data-keyword="PPC">PPC</button>
        <button type="button" data-keyword="Listing">Listing</button>
        <button type="button" data-keyword="Review">Review</button>
        <button type="button" data-keyword="选品">选品</button>
      </div>

      <div class="search-filters" id="ayan-search-filters">
        <div class="search-filter-group">
          <span class="search-filter-label">专题：</span>
          <button type="button" class="filter-pill" data-filter="topic" data-value="keyword">关键词</button>
          <button type="button" class="filter-pill" data-filter="topic" data-value="listing">Listing</button>
          <button type="button" class="filter-pill" data-filter="topic" data-value="ppc">PPC</button>
          <button type="button" class="filter-pill" data-filter="topic" data-value="review">Review</button>
          <button type="button" class="filter-pill" data-filter="topic" data-value="ai-search">AI 搜索</button>
          <button type="button" class="filter-pill" data-filter="topic" data-value="tools">工具</button>
          <button type="button" class="filter-pill" data-filter="topic" data-value="selection">选品</button>
          <button type="button" class="filter-pill filter-pill-clear" data-filter="topic" data-value="">不限</button>
        </div>
        <div class="search-filter-group">
          <span class="search-filter-label">阶段：</span>
          <button type="button" class="filter-pill" data-filter="stage" data-value="新手">新手</button>
          <button type="button" class="filter-pill" data-filter="stage" data-value="进阶">进阶</button>
          <button type="button" class="filter-pill" data-filter="stage" data-value="实操">实操</button>
          <button type="button" class="filter-pill filter-pill-clear" data-filter="stage" data-value="">不限</button>
        </div>
      </div>

      <div id="ayan-search-status" class="search-status">输入关键词后开始搜索。</div>
      <div id="ayan-search-results" class="search-results"></div>

      <div id="ayan-search-no-results" class="search-no-results" hidden>
        <div class="no-results-title">没有找到相关内容。试试这些专题学习路径：</div>
        <div class="no-results-grid">
          <a class="recommend-card" href="/articles/keyword-learning-path/">
            <div class="recommend-tag">学习路径</div>
            <div class="recommend-title">亚马逊关键词学习路径：从找词、清洗到布局</div>
            <div class="recommend-desc">把关键词拆成 4 步，按顺序跟读能跑通完整闭环。</div>
          </a>
          <a class="recommend-card" href="/articles/listing-learning-path/">
            <div class="recommend-tag">学习路径</div>
            <div class="recommend-title">亚马逊 Listing 优化学习路径：从卖点提炼到转化表达</div>
            <div class="recommend-desc">从卖点提炼到上线复盘，新手也能跑通。</div>
          </a>
          <a class="recommend-card" href="/articles/ppc-learning-path/">
            <div class="recommend-tag">学习路径</div>
            <div class="recommend-title">亚马逊 PPC 广告学习路径：从结构搭建到数据判断</div>
            <div class="recommend-desc">结构搭建、报表复盘、否词和预算、诊断迭代四步走。</div>
          </a>
          <a class="recommend-card" href="/articles/review-learning-path/">
            <div class="recommend-tag">学习路径</div>
            <div class="recommend-title">亚马逊 Review 分析学习路径：从评价挖掘到产品优化</div>
            <div class="recommend-desc">差评、好评、竞品反馈三类数据怎么用。</div>
          </a>
          <a class="recommend-card" href="/articles/ai-search-learning-path/">
            <div class="recommend-tag">学习路径</div>
            <div class="recommend-title">亚马逊 AI 搜索学习路径：从工具理解到运营应用</div>
            <div class="recommend-desc">Rufus / Alexa for Shopping 对卖家的影响与动作调整。</div>
          </a>
          <a class="recommend-card" href="/articles/tools-learning-path/">
            <div class="recommend-tag">学习路径</div>
            <div class="recommend-title">亚马逊工具资料学习路径：从表格、清单到实操 SOP</div>
            <div class="recommend-desc">把工具和资料拆成 4 类，搭建自己的运营工具链。</div>
          </a>
        </div>
        <div class="ask-entry-fallback">
          <a href="/ask/">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 5.3 18.5l3.7 1-1-3.7A10 10 0 0 0 12 2z"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
            没找到？试试问问 AI 阿岩助手 →
          </a>
        </div>
      </div>
    </section>
  </main>

  <script type="module">
    import * as pagefind from "/pagefind/pagefind.js";

    const input = document.querySelector("#ayan-search-input");
    const button = document.querySelector("#ayan-search-button");
    const status = document.querySelector("#ayan-search-status");
    const results = document.querySelector("#ayan-search-results");
    const noResultsEl = document.querySelector("#ayan-search-no-results");
    const tips = document.querySelectorAll("[data-keyword]");
    const filterPills = document.querySelectorAll(".filter-pill");

    const activeFilters = { topic: "", stage: "" };

    const topicLabelMap = {
      keyword: "关键词",
      listing: "Listing",
      ppc: "PPC",
      review: "Review",
      "ai-search": "AI 搜索",
      tools: "工具",
      selection: "选品"
    };

    function escapeHtml(text) {
      return String(text || "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function labelFor(filterName, rawValue) {
      if (!rawValue) return "";
      if (filterName === "topic") return topicLabelMap[rawValue] || rawValue;
      return rawValue;
    }

    function updatePillActiveState() {
      filterPills.forEach((pill) => {
        const f = pill.getAttribute("data-filter");
        const v = pill.getAttribute("data-value");
        const isActive = activeFilters[f] === v && v !== "";
        const isClear = v === "";
        const isCurrentClear = activeFilters[f] === "";
        pill.classList.toggle("active", isActive);
        pill.classList.toggle("active-clear", isClear && isCurrentClear);
      });
    }

    function buildPagefindFilters() {
      const out = {};
      for (const [k, v] of Object.entries(activeFilters)) {
        if (v) out[k] = v;
      }
      return out;
    }

    async function runSearch(keyword) {
      const q = String(keyword || "").trim();

      if (!q) {
        status.textContent = "输入关键词后开始搜索。";
        results.innerHTML = "";
        noResultsEl.hidden = true;
        return;
      }

      const filterObj = buildPagefindFilters();
      const filterCount = Object.keys(filterObj).length;
      status.textContent = filterCount > 0
        ? "正在搜索：" + q + "（已应用 " + filterCount + " 个筛选）"
        : "正在搜索：" + q;
      results.innerHTML = "";
      noResultsEl.hidden = true;

      try {
        const searchOptions = filterCount > 0 ? { filters: filterObj } : {};
        const search = await pagefind.search(q, searchOptions);

        if (!search || !search.results || search.results.length === 0) {
          status.textContent = filterCount > 0
            ? "没有找到同时匹配关键词和筛选的内容。试试调整筛选，或浏览下方专题学习路径。"
            : "没有找到相关内容。试试调整关键词，或浏览下方专题学习路径。";
          noResultsEl.hidden = false;
          return;
        }

        noResultsEl.hidden = true;
        status.textContent = "找到 " + search.results.length + " 条结果。";

        const data = await Promise.all(
          search.results.slice(0, 12).map((result) => result.data())
        );

        results.innerHTML = data.map((item) => {
          const title = escapeHtml(item.meta?.title || item.url || "未命名页面");
          const excerpt = item.excerpt || "";
          const url = item.url || "#";

          const topicRaw = item.meta?.topic || "";
          const stageRaw = item.meta?.stage || "";
          const intentRaw = item.meta?.intent || "";

          const topicLabel = labelFor("topic", topicRaw);
          const stageLabel = labelFor("stage", stageRaw);
          const intentLabel = labelFor("intent", intentRaw);

          const chips = [];
          if (topicLabel) chips.push(`<span class="result-chip result-chip-topic">专题·${topicLabel}</span>`);
          if (stageLabel) chips.push(`<span class="result-chip result-chip-stage">阶段·${stageLabel}</span>`);
          if (intentLabel) chips.push(`<span class="result-chip result-chip-intent">意图·${intentLabel}</span>`);

          return `
            <a class="result-card" href="${url}">
              <div class="result-title">${title}</div>
              <div class="result-excerpt">${excerpt}</div>
              ${chips.length > 0 ? `<div class="result-chips">${chips.join("")}</div>` : ""}
              <div class="result-url">${url}</div>
            </a>
          `;
        }).join("");
      } catch (err) {
        console.error(err);
        status.textContent = "搜索组件加载失败。请先 npm run build，再用 npm run preview 查看。";
        noResultsEl.hidden = true;
      }
    }

    button.addEventListener("click", () => runSearch(input.value));

    input.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        runSearch(input.value);
      }
    });

    input.addEventListener("input", () => {
      const q = input.value.trim();
      if (q.length >= 2) {
        window.clearTimeout(window.__ayanSearchTimer);
        window.__ayanSearchTimer = window.setTimeout(() => runSearch(q), 300);
      }
    });

    tips.forEach((tip) => {
      tip.addEventListener("click", () => {
        const keyword = tip.getAttribute("data-keyword");
        input.value = keyword;
        input.focus();
        runSearch(keyword);
      });
    });

    filterPills.forEach((pill) => {
      pill.addEventListener("click", () => {
        const f = pill.getAttribute("data-filter");
        const v = pill.getAttribute("data-value");
        if (v === "") {
          activeFilters[f] = "";
        } else if (activeFilters[f] === v) {
          activeFilters[f] = "";
        } else {
          activeFilters[f] = v;
        }
        updatePillActiveState();
        if (input.value.trim().length >= 2) {
          runSearch(input.value);
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .search-page {
    min-height: 100vh;
    padding: 56px 24px 80px;
    background:
      radial-gradient(circle at 24% 14%, rgba(19, 104, 255, 0.08), transparent 26%),
      linear-gradient(180deg, #f6f9fd 0%, #eef3fa 100%);
  }

  .search-hero {
    max-width: 960px;
    margin: 0 auto 24px;
  }

  .search-kicker {
    display: inline-flex;
    align-items: center;
    height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: #eef5ff;
    color: #1368ff;
    border: 1px solid #dceaff;
    font-size: 13px;
    font-weight: 900;
    margin-bottom: 14px;
  }

  .search-hero h1 {
    margin: 0;
    color: #0f172a;
    font-size: 44px;
    line-height: 1.16;
    letter-spacing: -1px;
  }

  .search-hero p {
    max-width: 720px;
    margin: 14px 0 0;
    color: #64748b;
    font-size: 17px;
    line-height: 1.8;
  }

  .search-card {
    max-width: 960px;
    margin: 0 auto;
    padding: 26px;
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(226, 232, 240, 0.96);
    box-shadow:
      0 24px 80px rgba(15, 23, 42, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
    position: relative;
    z-index: 20;
  }

  .search-box {
    display: grid;
    grid-template-columns: 1fr 110px;
    gap: 12px;
  }

  #ayan-search-input {
    width: 100%;
    height: 52px;
    border-radius: 15px;
    border: 1px solid #dce6f5;
    background: #ffffff;
    color: #0f172a;
    font-size: 16px;
    padding: 0 16px;
    outline: none;
    box-sizing: border-box;
    pointer-events: auto;
    user-select: text;
  }

  #ayan-search-input:focus {
    border-color: #1368ff;
    box-shadow: 0 0 0 4px rgba(19, 104, 255, 0.12);
  }

  #ayan-search-button {
    height: 52px;
    border: 0;
    border-radius: 15px;
    background: #1368ff;
    color: #fff;
    font-size: 16px;
    font-weight: 900;
    cursor: pointer;
    box-shadow: 0 12px 28px rgba(19, 104, 255, 0.2);
  }

  .search-tips {
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    align-items: center;
    color: #64748b;
    font-size: 14px;
  }

  .search-tips button {
    border: 1px solid #dceaff;
    background: #eef5ff;
    color: #1368ff;
    border-radius: 999px;
    padding: 7px 11px;
    font-weight: 800;
    cursor: pointer;
  }

  .search-filters {
    margin-top: 18px;
    padding: 16px;
    border-radius: 16px;
    background: #f7faff;
    border: 1px solid #e2ecfb;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .search-filter-group {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .search-filter-label {
    color: #475569;
    font-size: 13px;
    font-weight: 800;
    margin-right: 4px;
    min-width: 48px;
  }

  .filter-pill {
    border: 1px solid #dceaff;
    background: #ffffff;
    color: #1368ff;
    border-radius: 999px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 800;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .filter-pill:hover {
    border-color: #93c5fd;
    background: #eef5ff;
  }

  .filter-pill.active {
    background: #1368ff;
    color: #ffffff;
    border-color: #1368ff;
  }

  .filter-pill.filter-pill-clear {
    background: #f1f5f9;
    color: #64748b;
    border-color: #e2e8f0;
    font-weight: 700;
  }

  .filter-pill.filter-pill-clear.active-clear {
    background: #475569;
    color: #ffffff;
    border-color: #475569;
  }

  .search-status {
    margin-top: 22px;
    color: #64748b;
    font-size: 14px;
  }

  .search-results {
    margin-top: 16px;
    display: grid;
    gap: 14px;
  }

  .result-card {
    display: block;
    padding: 18px;
    border-radius: 18px;
    background:
      radial-gradient(circle at 92% 0%, rgba(19, 104, 255, 0.06), transparent 26%),
      #ffffff;
    border: 1px solid #e6eaf2;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
  }

  .result-card:hover {
    border-color: rgba(19, 104, 255, 0.34);
    box-shadow: 0 18px 48px rgba(19, 104, 255, 0.09);
  }

  .result-title {
    color: #0f172a;
    font-size: 19px;
    font-weight: 900;
    line-height: 1.45;
  }

  .result-excerpt {
    margin-top: 8px;
    color: #64748b;
    font-size: 14px;
    line-height: 1.8;
  }

  .result-excerpt mark {
    background: #fff2a8;
    color: #0f172a;
    padding: 0 2px;
    border-radius: 4px;
  }

  .result-chips {
    margin-top: 10px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .result-chip {
    display: inline-flex;
    align-items: center;
    height: 24px;
    padding: 0 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 800;
    line-height: 1;
  }

  .result-chip-topic {
    background: #eef5ff;
    color: #1368ff;
    border: 1px solid #cfe0ff;
  }

  .result-chip-stage {
    background: #f0fdf4;
    color: #16a34a;
    border: 1px solid #c7eed5;
  }

  .result-chip-intent {
    background: #fff7ed;
    color: #d97706;
    border: 1px solid #fde2bf;
  }

  .result-url {
    margin-top: 10px;
    color: #1368ff;
    font-size: 13px;
    word-break: break-all;
  }

  .search-no-results {
    margin-top: 22px;
    padding-top: 22px;
    border-top: 1px dashed #cbd5e1;
  }

  .no-results-title {
    color: #475569;
    font-size: 15px;
    font-weight: 800;
    margin-bottom: 14px;
  }

  .no-results-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .recommend-card {
    display: block;
    padding: 14px 16px;
    border-radius: 14px;
    background: linear-gradient(135deg, #eef5ff 0%, #f0f7ff 100%);
    border: 1px solid #cfe0ff;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .recommend-card:hover {
    transform: translateY(-1px);
    border-color: #93c5fd;
    box-shadow: 0 14px 30px rgba(19, 104, 255, 0.14);
  }

  .recommend-tag {
    display: inline-block;
    font-size: 11px;
    color: #1368ff;
    font-weight: 900;
    letter-spacing: 0.4px;
    margin-bottom: 6px;
  }

  .recommend-title {
    font-size: 14px;
    font-weight: 800;
    color: #0f172a;
    line-height: 1.5;
    margin-bottom: 4px;
  }

  .recommend-desc {
    font-size: 12px;
    color: #64748b;
    line-height: 1.5;
  }

  .ask-entry-fallback {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px dashed #cbd5e1;
  }

  .ask-entry-fallback a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 12px;
    background: linear-gradient(135deg, #eef5ff, #f5faff);
    border: 1px solid #cfe0ff;
    color: #1368ff;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .ask-entry-fallback a:hover {
    transform: translateY(-1px);
    border-color: #93c5fd;
    box-shadow: 0 8px 20px rgba(19, 104, 255, 0.10);
  }

  @media (max-width: 720px) {
    .search-page {
      padding: 34px 14px 56px;
    }

    .search-hero h1 {
      font-size: 34px;
    }

    .search-card {
      padding: 18px;
      border-radius: 22px;
    }

    .search-box {
      grid-template-columns: 1fr;
    }

    .no-results-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
