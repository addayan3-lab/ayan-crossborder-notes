---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="工具模板｜亚马逊 AI 运营检查表、Prompt 与复盘表" description="领取亚马逊 AI 运营工具模板，包括运营检查表、Listing 优化 Prompt、广告 PPC 复盘表和 Review 分析模板。">
  <section class="page-hero">
    <div class="page-hero-inner">
      <h1>工具模板</h1>
      <p>这里将放置 AI 运营检查表、Listing 优化 Prompt、广告复盘表和 Review 分析模板。</p>
    </div>
  </section>
  <section class="section">
    <div class="grid grid-3">
      <div class="card"><h3>AI 运营检查表</h3><p>用于判断一条运营任务是否适合交给 AI 辅助。</p></div>
      <div class="card"><h3>Listing 优化 Prompt</h3><p>用于生成标题、五点、描述和场景表达。</p></div>
      <div class="card"><h3>广告复盘表</h3><p>用于分析 ACOS、TACOS、CTR、CVR 和否词动作。</p></div>
    </div>
  </section>
</BaseLayout>