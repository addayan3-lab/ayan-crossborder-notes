---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import RecommendedOrder from "../../components/RecommendedOrder.astro";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);

const ayanBreadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://amz.hao1234.top/" },
    { "@type": "ListItem", "position": 2, "name": "工具模板", "item": "https://amz.hao1234.top/tools/" }
  ]
};
---
<BaseLayout title="工具模板｜亚马逊 AI 运营检查表、Prompt 与复盘表" description="领取亚马逊 AI 运营工具模板，包括运营检查表、Listing 优化 Prompt、广告 PPC 复盘表和 Review 分析模板。">
  <script type="application/ld+json" set:html={JSON.stringify(ayanBreadcrumbData)}></script>
  <section class="page-hero">
    <div class="page-hero-inner">
      <h1>工具模板</h1>
      <p>这里将放置 AI 运营检查表、Listing 优化 Prompt、广告复盘表和 Review 分析模板。</p>
    </div>
  </section>

  <section class="section">
    <div class="topic-intro">
      <h2>工具不是越多越好，能落到每天动作里才算数</h2>
      <p>这套资料包的思路，是把阿岩日常在用的检查表、Prompt 和复盘表整理成可下载版本。每个工具都对应一个明确的运营动作：判断、生成、复盘。</p>
      <p>领取后会通过企业微信发送，资料按专题持续更新，新工具更新时会在公开课和资料包同步通知。</p>
    </div>

    <a class="guide-card" href="/articles/tools-learning-path/">
      <div class="guide-card-hint">推荐先读 · 学习路径</div>
      <h3>亚马逊工具资料学习路径：从表格、清单到实操 SOP</h3>
      <p>把工具和资料拆成 4 类：检查表、Prompt 模板、复盘表、SOP。按顺序跟读，能搭建起自己的运营工具链。</p>
      <span class="guide-card-cta">看完整学习路径 →</span>
    </a>

    <div class="topic-articles">
      <h2 class="topic-articles-title">专题文章</h2>
      <div class="grid grid-2">
        <a class="card" href="/articles/amazon-platform-rules-beginner/">
          <h3>亚马逊平台规则入门：新手最容易踩的 10 个坑</h3>
          <p>讲清运营中最容易出问题的 10 个高频场景,以及怎么提前避免,适合作为风险提醒模块的开篇。</p>
        </a>
      </div>
    </div>

    <RecommendedOrder topic="tools" allPosts={allPosts} title="推荐学习顺序" />

    <div class="grid grid-3">
      <div class="card">
        <h3>AI 运营检查表</h3>
        <p>用于判断一条运营任务是否适合交给 AI 辅助。从任务类型、数据完整度、判断难度三个维度打分。</p>
        <a class="card-link" href="/lead/">领取 →</a>
      </div>
      <div class="card">
        <h3>Listing 优化 Prompt</h3>
        <p>用于生成标题、五点、描述和场景表达。包含产品信息输入模板、约束条件和质量自检步骤。</p>
        <a class="card-link" href="/lead/">领取 →</a>
      </div>
      <div class="card">
        <h3>广告复盘表</h3>
        <p>用于分析 ACOS、TACOS、CTR、CVR 和否词动作。包含周复盘、月复盘两套模板。</p>
        <a class="card-link" href="/lead/">领取 →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .topic-intro {
    max-width: 880px;
    margin: 0 0 28px;
    padding: 24px 28px;
    background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    border: 1px solid rgba(226, 232, 240, 0.95);
    border-radius: 20px;
    box-shadow:
      0 14px 40px rgba(15, 23, 42, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
  }

  .topic-intro h2 {
    margin: 0 0 14px;
    font-size: 22px;
    color: #0f172a;
    letter-spacing: -0.3px;
    position: relative;
    padding-left: 12px;
  }

  .topic-intro h2::before {
    content: "";
    position: absolute;
    left: 0;
    top: 4px;
    width: 4px;
    height: 22px;
    border-radius: 999px;
    background: #1368ff;
  }

  .topic-intro p {
    margin: 0 0 12px;
    color: #475569;
    line-height: 1.85;
    font-size: 15px;
  }

  .topic-intro p:last-child {
    margin-bottom: 0;
  }

  .guide-card {
    display: block;
    margin: 0 0 24px;
    padding: 24px 28px;
    border-radius: 20px;
    background:
      linear-gradient(135deg, #eef5ff 0%, #f0f7ff 100%);
    border: 1px solid #cfe0ff;
    box-shadow:
      0 14px 40px rgba(19, 104, 255, 0.10),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
    position: relative;
    overflow: hidden;
  }

  .guide-card::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(180deg, #1368ff, #7dd3fc);
  }

  .guide-card:hover {
    transform: translateY(-2px);
    border-color: #93c5fd;
    box-shadow:
      0 22px 56px rgba(19, 104, 255, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
  }

  .guide-card-hint {
    font-size: 11px;
    color: #1368ff;
    font-weight: 900;
    letter-spacing: 0.4px;
    margin-bottom: 10px;
  }

  .guide-card h3 {
    margin: 0 0 10px;
    color: #0f172a;
    font-size: 20px;
    line-height: 1.4;
  }

  .guide-card p {
    margin: 0 0 14px;
    color: #475569;
    line-height: 1.85;
    font-size: 15px;
  }

  .guide-card-cta {
    color: #1368ff;
    font-weight: 900;
    font-size: 14px;
  }

  .topic-articles {
    margin: 0 0 32px;
  }

  .topic-articles-title {
    margin: 0 0 16px;
    font-size: 20px;
    color: #0f172a;
    letter-spacing: -0.3px;
    position: relative;
    padding-left: 12px;
  }

  .topic-articles-title::before {
    content: "";
    position: absolute;
    left: 0;
    top: 4px;
    width: 4px;
    height: 20px;
    border-radius: 999px;
    background: #1368ff;
  }

  .card-link {
    display: inline-block;
    margin-top: 8px;
    color: #1368ff;
    font-weight: 800;
    font-size: 14px;
  }
</style>
