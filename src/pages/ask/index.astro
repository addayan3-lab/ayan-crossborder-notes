---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { assistantTopics } from "../../data/ayan-assistant-rules";
import { computeScoreForTopic } from "../../lib/ayan-assistant-match";
const topicsJson = JSON.stringify(assistantTopics);
const matchFnSource = computeScoreForTopic.toString();
---

<BaseLayout title="AI 阿岩助手｜阿岩跨境笔记" description="输入你在亚马逊运营中遇到的问题，AI 阿岩助手会推荐对应的文章、工具模板和公开课。纯本地规则匹配，你的输入不会被上传或存储，无需担心隐私。">
  <main class="ask-page">
    <section class="ask-hero">
      <div class="ask-kicker">AI 阿岩助手</div>
      <h1>问问 AI 阿岩助手</h1>
      <p>输入你在亚马逊运营中遇到的问题，我会推荐对应的文章、模板和公开课。<br />你的输入仅在你自己的浏览器中处理，不会被上传或存储。</p>
    </section>

    <section class="ask-card">
      <div class="ask-box">
        <input id="ayan-ask-input" type="text" placeholder="比如：不知道怎么找关键词、广告 ACOS 太高、Listing 转化率低……" autocomplete="off" />
        <button id="ayan-ask-button" type="button">问问 AI</button>
      </div>

      <div class="ask-scenes">
        <button type="button" class="ask-scene-btn" data-ask="我是亚马逊新手，应该先学什么？">
          <span class="ask-scene-icon">🧭</span>
          <span class="ask-scene-label">新手入门</span>
          <span class="ask-scene-desc">不知道从哪开始，先建立学习路径</span>
        </button>
        <button type="button" class="ask-scene-btn" data-ask="我已经有产品，想判断还能不能做">
          <span class="ask-scene-icon">📦</span>
          <span class="ask-scene-label">有产品待诊断</span>
          <span class="ask-scene-desc">市场容量和竞品判断</span>
        </button>
        <button type="button" class="ask-scene-btn" data-ask="广告 ACOS 太高，应该怎么优化？">
          <span class="ask-scene-icon">📢</span>
          <span class="ask-scene-label">广告 ACOS 高</span>
          <span class="ask-scene-desc">报表分析和结构优化</span>
        </button>
        <button type="button" class="ask-scene-btn" data-ask="Listing 有流量但转化差，应该先改哪里？">
          <span class="ask-scene-icon">📝</span>
          <span class="ask-scene-label">Listing 转化差</span>
          <span class="ask-scene-desc">五点写法与自检清单</span>
        </button>
        <button type="button" class="ask-scene-btn" data-ask="差评怎么用来优化页面和产品？">
          <span class="ask-scene-icon">⭐</span>
          <span class="ask-scene-label">差评怎么改</span>
          <span class="ask-scene-desc">差评归因与 Listing 修复</span>
        </button>
      </div>

      <div class="ask-presets">
        <span>试试问：</span>
        <button type="button" data-ask="不知道怎么找关键词">不知道怎么找关键词</button>
        <button type="button" data-ask="广告 ACOS 太高怎么办">广告 ACOS 太高怎么办</button>
        <button type="button" data-ask="Listing 怎么优化">Listing 怎么优化</button>
        <button type="button" data-ask="怎么分析差评">怎么分析差评</button>
        <button type="button" data-ask="新手从哪里开始">新手从哪里开始</button>
      </div>

      <div class="ask-result" id="ayan-ask-result" hidden>
        <div class="ask-result-topic-label" id="ayan-result-label"></div>
        <div class="ask-result-suggestion" id="ayan-result-suggestion"></div>

        <div class="ask-result-section" id="ayan-result-steps-section" hidden>
          <h3>建议步骤</h3>
          <ol id="ayan-result-steps"></ol>
        </div>

        <div class="ask-result-section" id="ayan-result-articles-section" hidden>
          <h3>推荐阅读</h3>
          <div class="ask-result-grid" id="ayan-result-articles"></div>
        </div>

        <div class="ask-result-extras" id="ayan-result-extras" hidden>
          <div class="ask-result-extras-trigger">查看配套资源 ▾</div>
          <div class="ask-result-extras-body" id="ayan-result-extras-body" hidden>
            <div id="ayan-result-extras-content"></div>
          </div>
        </div>
      </div>

      <div class="ask-fallback" id="ayan-ask-fallback" hidden>
        <p class="ask-fallback-text">我还不能确定你的问题属于哪一类，试试从下面的方向中选择：</p>
        <div class="ask-fallback-buttons">
          <button type="button" data-ask="不知道怎么找关键词">🔑 关键词</button>
          <button type="button" data-ask="Listing 怎么优化">📝 Listing</button>
          <button type="button" data-ask="广告 ACOS 太高怎么办">📢 PPC 广告</button>
          <button type="button" data-ask="怎么分析差评">⭐ Review 差评</button>
          <button type="button" data-ask="想判断一个产品能不能做">📦 选品</button>
        </div>
      </div>
    </section>
  </main>

  <div id="ayan-topics-data" style="display:none" set:html={topicsJson}></div>

  <script is:inline set:html={`window.computeScoreForTopic = ${matchFnSource};`}></script>

  <script type="module">
    const topics = JSON.parse(document.getElementById("ayan-topics-data").textContent);

    const input = document.querySelector("#ayan-ask-input");
    const button = document.querySelector("#ayan-ask-button");
    const presets = document.querySelectorAll("[data-ask]");
    const resultEl = document.querySelector("#ayan-ask-result");
    const labelEl = document.querySelector("#ayan-result-label");
    const suggestionEl = document.querySelector("#ayan-result-suggestion");
    const stepsSection = document.querySelector("#ayan-result-steps-section");
    const stepsEl = document.querySelector("#ayan-result-steps");
    const articlesSection = document.querySelector("#ayan-result-articles-section");
    const articlesEl = document.querySelector("#ayan-result-articles");
    const extrasEl = document.querySelector("#ayan-result-extras");
    const extrasBody = document.querySelector("#ayan-result-extras-body");
    const extrasContent = document.querySelector("#ayan-result-extras-content");

    function matchTopic(query) {
      const q = query.toLowerCase();
      let best = null;
      let bestScore = 0;
      for (const topic of topics) {
        const score = window.computeScoreForTopic(q, topic.triggerKeywords, topic.strongKeywords || []);
        if (score > bestScore) {
          bestScore = score;
          best = topic;
        }
      }
      return bestScore > 0 ? best : null;
    }

    function displayResult(topic) {
      if (!topic) return;
      document.querySelector("#ayan-ask-fallback").hidden = true;

      labelEl.textContent = "专题：" + topic.label;
      suggestionEl.textContent = topic.suggestion;

      if (topic.steps && topic.steps.length > 0) {
        stepsSection.hidden = false;
        stepsEl.innerHTML = topic.steps.map((s) => `<li>${s}</li>`).join("");
      } else {
        stepsSection.hidden = true;
      }

      if (topic.articles && topic.articles.length > 0) {
        articlesSection.hidden = false;
        articlesEl.innerHTML = topic.articles.map((a) => `
          <a class="ask-result-item" href="/articles/${a.slug}/">
            <div class="ask-result-item-title">${a.title}</div>
            <div class="ask-result-item-desc">${a.desc}</div>
          </a>
        `).join("");
      } else {
        articlesSection.hidden = true;
      }

      const hasResources = topic.resources && topic.resources.length > 0;
      const hasClasses = topic.openClasses && topic.openClasses.length > 0;
      if (hasResources || hasClasses) {
        extrasEl.hidden = false;
        const parts = [];
        if (hasResources) {
          topic.resources.forEach((r) => {
            parts.push('<div class="ask-extras-item"><span class="ask-extras-label">资料</span><a href="/resources/">' + r.title + '</a></div>');
          });
        }
        if (hasClasses) {
          topic.openClasses.forEach((oc) => {
            parts.push('<div class="ask-extras-item"><span class="ask-extras-label">课程</span><a href="/open-class/">' + oc.title + '</a></div>');
          });
        }
        const firstRes = topic.resources && topic.resources.length > 0 ? topic.resources[0] : null;
        if (firstRes && firstRes.wechatHook) {
          parts.push('<div class="ask-extras-wechat">' + firstRes.wechatHook + '</div>');
        }
        extrasContent.innerHTML = parts.join("");
      } else {
        extrasEl.hidden = true;
      }

      resultEl.hidden = false;
    }

    function showFallback() {
      resultEl.hidden = true;
      document.querySelector("#ayan-ask-fallback").hidden = false;
    }

    function runAsk(query) {
      const q = String(query || "").trim();
      if (!q) return;
      const topic = matchTopic(q);
      if (topic) {
        displayResult(topic);
      } else {
        showFallback();
      }
    }

    button.addEventListener("click", () => runAsk(input.value));

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") runAsk(input.value);
    });

    presets.forEach((btn) => {
      btn.addEventListener("click", () => {
        const q = btn.getAttribute("data-ask");
        input.value = q;
        input.focus();
        runAsk(q);
      });
    });

    const extrasTrigger = document.querySelector(".ask-result-extras-trigger");
    if (extrasTrigger) {
      extrasTrigger.addEventListener("click", () => {
        const body = document.querySelector("#ayan-result-extras-body");
        if (body) {
          const isHidden = body.hidden;
          body.hidden = !isHidden;
          extrasTrigger.textContent = isHidden ? "收起配套资源 ▴" : "查看配套资源 ▾";
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .ask-page {
    min-height: 100vh;
    padding: 56px 24px 80px;
    background:
      radial-gradient(circle at 24% 14%, rgba(19, 104, 255, 0.08), transparent 26%),
      linear-gradient(180deg, #f6f9fd 0%, #eef3fa 100%);
  }

  .ask-hero {
    max-width: 860px;
    margin: 0 auto 24px;
  }

  .ask-kicker {
    display: inline-flex;
    align-items: center;
    height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: linear-gradient(135deg, #eef5ff, #e0edff);
    color: #1368ff;
    border: 1px solid #cfe0ff;
    font-size: 13px;
    font-weight: 900;
    margin-bottom: 14px;
  }

  .ask-hero h1 {
    margin: 0;
    color: #0f172a;
    font-size: 44px;
    line-height: 1.16;
    letter-spacing: -1px;
  }

  .ask-hero p {
    max-width: 720px;
    margin: 14px 0 0;
    color: #64748b;
    font-size: 15px;
    line-height: 1.8;
  }

  .ask-card {
    max-width: 860px;
    margin: 0 auto;
    padding: 26px;
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(226, 232, 240, 0.96);
    box-shadow:
      0 24px 80px rgba(15, 23, 42, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
  }

  .ask-box {
    display: grid;
    grid-template-columns: 1fr 110px;
    gap: 12px;
  }

  #ayan-ask-input {
    width: 100%;
    height: 52px;
    border-radius: 15px;
    border: 1px solid #dce6f5;
    background: #ffffff;
    color: #0f172a;
    font-size: 16px;
    padding: 0 16px;
    outline: none;
    box-sizing: border-box;
  }

  #ayan-ask-input:focus {
    border-color: #1368ff;
    box-shadow: 0 0 0 4px rgba(19, 104, 255, 0.12);
  }

  #ayan-ask-button {
    height: 52px;
    border: 0;
    border-radius: 15px;
    background: linear-gradient(135deg, #1368ff, #2563eb);
    color: #fff;
    font-size: 16px;
    font-weight: 900;
    cursor: pointer;
    box-shadow: 0 12px 28px rgba(19, 104, 255, 0.2);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  #ayan-ask-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 16px 36px rgba(19, 104, 255, 0.28);
  }

  .ask-presets {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    color: #64748b;
    font-size: 14px;
  }

  .ask-presets button {
    border: 1px solid #dceaff;
    background: #eef5ff;
    color: #1368ff;
    border-radius: 999px;
    padding: 7px 12px;
    font-weight: 800;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .ask-presets button:hover {
    border-color: #93c5fd;
    background: #e0edff;
  }

  .ask-result {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid #e2e8f0;
  }

  .ask-result-topic-label {
    display: inline-flex;
    align-items: center;
    height: 28px;
    padding: 0 12px;
    border-radius: 999px;
    background: #eef5ff;
    color: #1368ff;
    border: 1px solid #cfe0ff;
    font-size: 13px;
    font-weight: 900;
    margin-bottom: 14px;
  }

  .ask-result-suggestion {
    color: #0f172a;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.7;
    margin-bottom: 18px;
    padding: 14px 18px;
    border-radius: 14px;
    background: linear-gradient(135deg, #f0f7ff, #f5faff);
    border: 1px solid #dceaff;
  }

  .ask-result-section {
    margin-top: 20px;
  }

  .ask-result-section h3 {
    margin: 0 0 12px;
    font-size: 17px;
    color: #0f172a;
  }

  .ask-result-grid {
    display: grid;
    gap: 10px;
  }

  .ask-result-item {
    display: block;
    padding: 14px 16px;
    border-radius: 14px;
    background: #ffffff;
    border: 1px solid #e6eaf2;
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .ask-result-item:hover {
    border-color: rgba(19, 104, 255, 0.34);
    box-shadow: 0 8px 20px rgba(19, 104, 255, 0.08);
  }

  .ask-result-item-title {
    color: #0f172a;
    font-size: 15px;
    font-weight: 800;
    line-height: 1.5;
    margin-bottom: 4px;
  }

  .ask-result-item-desc {
    color: #64748b;
    font-size: 13px;
    line-height: 1.6;
  }

  .ask-result-extras {
    margin-top: 20px;
  }

  .ask-result-extras-trigger {
    cursor: pointer;
    color: #1368ff;
    font-size: 14px;
    font-weight: 800;
    padding: 10px 14px;
    border-radius: 10px;
    background: #f0f7ff;
    border: 1px solid #dceaff;
    display: inline-block;
    user-select: none;
    transition: background 0.15s ease;
  }

  .ask-result-extras-trigger:hover {
    background: #e0edff;
  }

  .ask-result-extras-body {
    margin-top: 12px;
    padding: 14px 16px;
    border-radius: 14px;
    background: #fafbfc;
    border: 1px solid #e6eaf2;
  }

  .ask-extras-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 0;
    font-size: 14px;
  }

  .ask-extras-label {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    height: 22px;
    padding: 0 8px;
    border-radius: 999px;
    background: #eef5ff;
    color: #1368ff;
    font-size: 11px;
    font-weight: 900;
  }

  .ask-extras-item a {
    color: #1e3a5f;
    font-weight: 600;
    text-decoration: none;
  }

  .ask-extras-item a:hover {
    color: #1368ff;
  }

  .ask-extras-wechat {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid #e2e8f0;
    color: #64748b;
    font-size: 13px;
  }

  .ask-result-steps ol {
    margin: 0;
    padding-left: 20px;
  }

  .ask-result-steps li {
    color: #334155;
    line-height: 1.8;
    font-size: 14px;
  }

  .ask-scenes {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    margin: 18px 0;
  }

  .ask-scene-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 14px 8px;
    border: 1px solid #dceaff;
    background: linear-gradient(135deg, #f6fafe, #eef5ff);
    color: #0f172a;
    border-radius: 16px;
    cursor: pointer;
    transition: all 0.15s ease;
    text-align: center;
    font-family: inherit;
  }

  .ask-scene-btn:hover {
    border-color: #93c5fd;
    background: linear-gradient(135deg, #eef5ff, #e0edff);
  }

  .ask-scene-icon {
    font-size: 22px;
    line-height: 1;
  }

  .ask-scene-label {
    font-size: 14px;
    font-weight: 800;
    color: #1368ff;
  }

  .ask-scene-desc {
    font-size: 11px;
    color: #64748b;
    line-height: 1.4;
  }

  .ask-fallback {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid #e2e8f0;
  }

  .ask-fallback-text {
    color: #64748b;
    font-size: 15px;
    margin: 0 0 16px;
    line-height: 1.7;
  }

  .ask-fallback-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .ask-fallback-buttons button {
    border: 1px solid #dceaff;
    background: #eef5ff;
    color: #1368ff;
    border-radius: 999px;
    padding: 7px 14px;
    font-weight: 800;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
    font-family: inherit;
    font-size: 14px;
  }

  .ask-fallback-buttons button:hover {
    border-color: #93c5fd;
    background: #e0edff;
  }

  @media (max-width: 720px) {
    .ask-page {
      padding: 34px 14px 56px;
    }

    .ask-hero h1 {
      font-size: 34px;
    }

    .ask-card {
      padding: 18px;
      border-radius: 22px;
    }

    .ask-box {
      grid-template-columns: 1fr;
    }

    .ask-scenes {
      grid-template-columns: repeat(2, 1fr);
    }

    .ask-presets {
      gap: 8px;
    }
  }
</style>
