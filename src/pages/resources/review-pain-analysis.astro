    box-shadow: 0 12px 32px rgba(19, 104, 255, 0.08);
  }

  .related-tag {
    display: inline-block;
    margin-bottom: 10px;
    padding: 3px 9px;
    background: #eef5ff;
    color: #1368ff;
    font-size: 11px;
    font-weight: 900;
    border-radius: 999px;
  }

  .related-card h3 {
    margin: 0 0 8px;
    font-size: 16px;
    color: #0f172a;
    line-height: 1.4;
  }

  .related-card p {
    margin: 0;
    color: #475569;
    font-size: 13px;
    line-height: 1.7;
  }

  .learning-path-card {
    display: block;
    padding: 22px 26px;
    border-radius: 16px;
