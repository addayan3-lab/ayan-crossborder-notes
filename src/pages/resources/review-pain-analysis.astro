  }

  .learning-path-card:hover {
    transform: translateY(-2px);
    border-color: #93c5fd;
    box-shadow: 0 16px 40px rgba(19, 104, 255, 0.14);
  }

  .lp-hint {
    font-size: 11px;
    color: #1368ff;
    font-weight: 900;
    letter-spacing: 0.4px;
    margin-bottom: 10px;
  }

  .learning-path-card h3 {
    margin: 0 0 8px;
    color: #0f172a;
    font-size: 18px;
  }

  .learning-path-card p {
    margin: 0 0 12px;
    color: #475569;
    line-height: 1.75;
    font-size: 14px;
  }

  .lp-cta {
    color: #1368ff;
    font-weight: 900;
    font-size: 14px;
  }

  .callout-amber {
    padding: 20px 24px;
    background: linear-gradient(135deg, #fffcf0 0%, #fef6e0 100%);
    border: 1px solid #f4d089;
    border-left: 4px solid #d97706;
    border-radius: 12px;
  }

  .callout-amber strong {
    display: block;
    color: #b45309;
    font-size: 15px;
    margin-bottom: 10px;
  }

  .callout-amber p {
    margin: 0 0 10px;
    color: #57534e;
    line-height: 1.85;
    font-size: 14px;
  }

  .callout-amber p:last-child {
    margin-bottom: 0;
  }

  .cta-block {
    margin: 0 0 24px;
    padding: 28px 32px;
    border-radius: 18px;
    background: linear-gradient(135deg, #fffcf0 0%, #fef6e0 100%);
    border: 1px solid #f4d089;
    text-align: center;
  }

  .cta-hint {
    display: inline-block;
    margin-bottom: 12px;
    padding: 4px 12px;
    background: #ffffff;
    color: #b45309;
    border: 1px solid #f4d089;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.4px;
  }

  .cta-block h2 {
    margin: 0 0 10px;
    color: #0f172a;
    font-size: 24px;
    letter-spacing: -0.4px;
  }

  .cta-block p {
    margin: 0 0 22px;
    color: #475569;
    font-size: 15px;
  }

  .cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 46px;
    padding: 0 24px;
    border-radius: 12px;
    font-weight: 900;
    font-size: 14px;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .cta-primary {
    background: linear-gradient(135deg, #d97706, #f59e0b);
    color: #ffffff;
    box-shadow: 0 12px 28px rgba(217, 119, 6, 0.22);
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(217, 119, 6, 0.32);
  }

  .cta-secondary {
    background: #ffffff;
    color: #b45309;
    border: 1px solid #f4d089;
  }

  .cta-secondary:hover {
    transform: translateY(-2px);
    border-color: #d97706;
  }

  @media (max-width: 980px) {
    .info-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .related-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .info-grid {
      grid-template-columns: 1fr;
    }
    .field-row {
      grid-template-columns: 1fr;
    }
    .field-name {
      border-right: 0;
      border-bottom: 1px solid #fef3c7;
      background: #fffbeb;
    }
  }
</style>
