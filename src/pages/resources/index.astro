  "amazon-ai-tools-review": "ai-tools-review-sheet",
  "amazon-platform-rules-beginner": "platform-rules-checklist"
};

const ayanBreadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://amz.hao1234.top/" },
    { "@type": "ListItem", "position": 2, "name": "资源中心", "item": "https://amz.hao1234.top/resources/" }
  ]
