---
const { post, allPosts } = Astro.props;

const articleIndex = {};
if (Array.isArray(allPosts)) {
  for (const p of allPosts) {
    if (p && p.id) {
      articleIndex[p.id] = p.data;
    }
  }
}

const prevSlug = post?.data?.prevArticle;
const nextSlug = post?.data?.nextArticle;
const relatedLinks = Array.isArray(post?.data?.relatedArticleLinks) ? post.data.relatedArticleLinks : [];

const relatedBySlug = Object.fromEntries(
  relatedLinks.map((link) => [link.slug, { label: link.label, context: link.context }])
);

const prevArticle = prevSlug && articleIndex[prevSlug] ? { slug: prevSlug, ...articleIndex[prevSlug] } : null;
const nextArticle = nextSlug && articleIndex[nextSlug] ? { slug: nextSlug, ...articleIndex[nextSlug] } : null;

function navLabel(slug, fallback) {
  return relatedBySlug[slug]?.context || fallback;
}

function navTitle(slug, articleTitle) {
  return relatedBySlug[slug]?.label || articleTitle;
}

const hasNav = prevArticle || nextArticle || relatedLinks.length > 0;
---

{hasNav && (
  <section class="article-nav-hints" aria-label="文章导航">
    {(prevArticle || nextArticle) && (
      <div class="article-nav-seq">
        {prevArticle && (
          <a href={`/articles/${prevArticle.slug}/`} target="_blank" rel="noopener noreferrer" class="article-nav-seq-link article-nav-prev">
            <span class="article-nav-seq-arrow">←</span>
            <div class="article-nav-seq-body">
              <span class="article-nav-seq-label">{navLabel(prevArticle.slug, "上一篇")}</span>
              <span class="article-nav-seq-title">{navTitle(prevArticle.slug, prevArticle.title)}</span>
            </div>
          </a>
        )}
        {nextArticle && (
          <a href={`/articles/${nextArticle.slug}/`} target="_blank" rel="noopener noreferrer" class="article-nav-seq-link article-nav-next">
            <div class="article-nav-seq-body">
              <span class="article-nav-seq-label">{navLabel(nextArticle.slug, "下一篇")}</span>
              <span class="article-nav-seq-title">{navTitle(nextArticle.slug, nextArticle.title)}</span>
            </div>
            <span class="article-nav-seq-arrow">→</span>
          </a>
        )}
      </div>
    )}
    {relatedLinks.length > 0 && (
      <div class="article-nav-related">
        <span class="article-nav-related-title">系列文章</span>
        <div class="article-nav-related-list">
          {relatedLinks.map((link) => {
            const resolved = articleIndex[link.slug];
            return (
              <a
                href={`/articles/${link.slug}/`}
                target="_blank"
                rel="noopener noreferrer"
                class="article-nav-related-item"
              >
                <span class="article-nav-related-label">{link.context || link.label}</span>
                {resolved && <span class="article-nav-related-headline">{link.label || resolved.title}</span>}
              </a>
            );
          })}
        </div>
      </div>
    )}
  </section>
)}

<style is:global>
  .article-nav-hints {
    margin: 16px 52px 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .article-nav-seq {
    display: flex;
    gap: 10px;
  }

  .article-nav-seq-link {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-radius: 10px;
    background: #fafbfc;
    border: 1px solid #eef1f6;
    color: inherit;
    text-decoration: none;
    min-width: 0;
  }

  .article-nav-seq-link:hover {
    background: #f2f5fa;
    border-color: #dce2ec;
  }

  .article-nav-prev {
    text-align: left;
  }

  .article-nav-next {
    text-align: right;
    justify-content: flex-end;
  }

  .article-nav-seq-arrow {
    font-size: 16px;
    color: #64748b;
    flex-shrink: 0;
  }

  .article-nav-seq-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .article-nav-seq-label {
    font-size: 11px;
    color: #94a3b8;
    font-weight: 700;
    letter-spacing: 0.3px;
  }

  .article-nav-seq-title {
    font-size: 13px;
    font-weight: 700;
    color: #334155;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-nav-related {
    padding: 12px 14px;
    border-radius: 10px;
    background: #fafbfc;
    border: 1px solid #eef1f6;
  }

  .article-nav-related-title {
    display: block;
    font-size: 11px;
    color: #94a3b8;
    font-weight: 700;
    letter-spacing: 0.3px;
    margin-bottom: 8px;
  }

  .article-nav-related-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .article-nav-related-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 12px;
    border-radius: 999px;
    background: #ffffff;
    border: 1px solid #eef1f6;
    color: inherit;
    text-decoration: none;
    font-size: 13px;
  }

  .article-nav-related-item:hover {
    background: #f2f5fa;
    border-color: #dce2ec;
  }

  .article-nav-related-label {
    font-weight: 800;
    color: #64748b;
    flex-shrink: 0;
  }

  .article-nav-related-headline {
    color: #334155;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 180px;
  }

  .article-nav-related-context {
    color: #94a3b8;
    font-size: 12px;
  }

  @media (max-width: 720px) {
    .article-nav-hints {
      margin-left: 24px;
      margin-right: 24px;
    }

    .article-nav-seq {
      flex-direction: column;
    }
  }
</style>
