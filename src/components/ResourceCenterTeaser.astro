---
const teaserResources = [
  { icon: '🧹', name: '关键词清洗表' },
  { icon: '📋', name: 'Listing 自检清单' },
  { icon: '📊', name: 'PPC 复盘表' },
  { icon: '🎯', name: 'Review 痛点分析表' }
];
---

<section class="resource-center-teaser" aria-label="免费资料包">
  <div class="teaser-text">
    <h2>免费资料包</h2>
    <p>关键词表、Listing 自检表、PPC 复盘表、Review 分析表、选品矩阵和 AI 工具清单，集中放在资源中心。</p>
  </div>
  <div class="teaser-chips" aria-label="代表资料包">
    {teaserResources.map((r) => (
      <div class="teaser-chip">
        <span class="teaser-chip-icon" aria-hidden="true">{r.icon}</span>
        <span class="teaser-chip-name">{r.name}</span>
      </div>
    ))}
  </div>
  <a class="teaser-cta" href="/resources/" aria-label="查看全部资料包">
    <span>查看全部资料包</span>
    <span class="teaser-cta-arrow" aria-hidden="true">→</span>
  </a>
</section>

<style>
  .resource-center-teaser {
    margin: 32px 0 0;
    padding: 26px 30px;
    border-radius: 22px;
    background:
      radial-gradient(circle at 100% 0%, rgba(217, 119, 6, 0.10), transparent 30%),
      linear-gradient(180deg, #fffcf0 0%, #fef9e7 100%);
    border: 1px solid rgba(217, 119, 6, 0.22);
    box-shadow: 0 18px 48px rgba(217, 119, 6, 0.08);
    display: grid;
    grid-template-columns: minmax(240px, 1.1fr) minmax(0, 1.6fr) auto;
    gap: 26px;
    align-items: center;
  }

  .teaser-text h2 {
    margin: 0 0 10px;
    font-size: 22px;
    font-weight: 900;
    color: #5c3d0c;
    letter-spacing: -0.3px;
    position: relative;
    padding-left: 12px;
  }

  .teaser-text h2::before {
    content: "";
    position: absolute;
    left: 0;
    top: 4px;
    width: 4px;
    height: 22px;
    border-radius: 999px;
    background: #d97706;
  }

  .teaser-text p {
    margin: 0;
    color: #5c3d0c;
    font-size: 14px;
    line-height: 1.75;
  }

  .teaser-chips {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .teaser-chip {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 11px 14px;
    border-radius: 12px;
    background: #ffffff;
    border: 1px solid rgba(217, 119, 6, 0.20);
    box-shadow: 0 4px 12px rgba(217, 119, 6, 0.05);
  }

  .teaser-chip-icon {
    font-size: 17px;
    flex-shrink: 0;
  }

  .teaser-chip-name {
    font-size: 13px;
    font-weight: 800;
    color: #0f172a;
    line-height: 1.4;
  }

  .teaser-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 46px;
    padding: 0 22px;
    border-radius: 13px;
    background: #d97706;
    color: #ffffff;
    font-weight: 900;
    font-size: 14px;
    text-decoration: none;
    box-shadow: 0 12px 28px rgba(217, 119, 6, 0.24);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    white-space: nowrap;
  }

  .teaser-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 16px 36px rgba(217, 119, 6, 0.30);
  }

  .teaser-cta-arrow {
    font-size: 18px;
    transition: transform 0.15s ease;
  }

  .teaser-cta:hover .teaser-cta-arrow {
    transform: translateX(2px);
  }

  @media (max-width: 980px) {
    .resource-center-teaser {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .teaser-cta {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 600px) {
    .teaser-chips {
      grid-template-columns: 1fr;
    }
  }
</style>
