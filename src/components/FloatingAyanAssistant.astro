---
import { assistantTopics } from "../data/ayan-assistant-rules";
import { computeScoreForTopic } from "../lib/ayan-assistant-match";
const topicsJson = JSON.stringify(assistantTopics);
const matchFnSource = computeScoreForTopic.toString();
---
<div class="ayan-floating-wrap">
  <button class="ayan-floating-trigger" id="ayan-floating-trigger" aria-label="阿岩助手" type="button">
    <div class="ayan-floating-trigger-title">阿岩助手</div>
    <div class="ayan-floating-trigger-text">问问 AI</div>
  </button>

  <div class="ayan-floating-panel" id="ayan-floating-panel" hidden>
    <div class="ayan-floating-head">
      <div>
        <div class="ayan-floating-title">AI 阿岩助手</div>
        <div class="ayan-floating-subtitle">输入你的亚马逊运营问题，我会根据站内文章、资料和公开课给你推荐下一步。</div>
      </div>
      <button class="ayan-floating-close" id="ayan-floating-close" aria-label="关闭" type="button">×</button>
    </div>

    <div class="ayan-floating-body">
      <div class="ayan-floating-input-row">
        <input id="ayan-floating-input" type="text" placeholder="比如：广告 ACOS 太高怎么办？" autocomplete="off" />
        <button id="ayan-floating-ask-btn" type="button">问问</button>
      </div>

      <div class="ayan-floating-quick" id="ayan-floating-quick">
        <div class="ayan-floating-quick-label">快捷问题：</div>
        <button type="button" data-ask="新品广告第一周怎么开？">新品广告第一周怎么开？</button>
        <button type="button" data-ask="Listing 转化差怎么办？">Listing 转化差怎么办？</button>
        <button type="button" data-ask="差评怎么用来优化页面？">差评怎么用来优化页面？</button>
        <button type="button" data-ask="想判断一个产品能不能做">想判断一个产品能不能做</button>
      </div>

      <div class="ayan-floating-result" id="ayan-floating-result" hidden>
        <div class="ayan-floating-result-topic" id="ayan-floating-result-topic"></div>
        <div class="ayan-floating-result-suggestion" id="ayan-floating-result-suggestion"></div>
        <div class="ayan-floating-result-articles" id="ayan-floating-result-articles"></div>
      </div>

      <div class="ayan-floating-fallback" id="ayan-floating-fallback" hidden>
        <p class="ayan-floating-fallback-text">试试从下面的方向中选择：</p>
        <div class="ayan-floating-fallback-btns">
          <button type="button" data-ask="不知道怎么找关键词">🔑 关键词</button>
          <button type="button" data-ask="Listing 怎么优化">📝 Listing</button>
          <button type="button" data-ask="广告 ACOS 太高怎么办">📢 PPC</button>
          <button type="button" data-ask="怎么分析差评">⭐ Review</button>
          <button type="button" data-ask="想判断一个产品能不能做">📦 选品</button>
          <button type="button" data-ask="公开课讲什么">🎓 公开课</button>
        </div>
      </div>
    </div>

    <div class="ayan-floating-footer">
      <a href="/survey/" class="ayan-floating-footer-link">做 30 秒资料诊断 →</a>
      <a href="/ask/" class="ayan-floating-footer-link">打开完整助手页 →</a>
    </div>
  </div>
</div>

<div id="ayan-floating-topics-data" style="display:none" set:html={topicsJson}></div>

<script is:inline set:html={`window.ayanFloatingMatchFn = ${matchFnSource};`}></script>

<script type="module">
  const topics = JSON.parse(document.getElementById("ayan-floating-topics-data").textContent);

  const wrap = document.querySelector(".ayan-floating-wrap");
  const trigger = document.getElementById("ayan-floating-trigger");
  const panel = document.getElementById("ayan-floating-panel");
  const closeBtn = document.getElementById("ayan-floating-close");
  const input = document.getElementById("ayan-floating-input");
  const askBtn = document.getElementById("ayan-floating-ask-btn");
  const quickBtns = document.querySelectorAll("#ayan-floating-quick [data-ask], #ayan-floating-fallback [data-ask]");
  const resultEl = document.getElementById("ayan-floating-result");
  const topicEl = document.getElementById("ayan-floating-result-topic");
  const suggestionEl = document.getElementById("ayan-floating-result-suggestion");
  const articlesEl = document.getElementById("ayan-floating-result-articles");
  const fallbackEl = document.getElementById("ayan-floating-fallback");
  const quickSection = document.getElementById("ayan-floating-quick");

  function openPanel() {
    panel.hidden = false;
    wrap.classList.add("is-open");
    trigger.setAttribute("aria-expanded", "true");
    input.focus();
  }

  function closePanel() {
    panel.hidden = true;
    wrap.classList.remove("is-open");
    trigger.setAttribute("aria-expanded", "false");
    resultEl.hidden = true;
    fallbackEl.hidden = true;
    quickSection.hidden = false;
    input.value = "";
  }

  function matchTopic(query) {
    const q = query.toLowerCase();
    let best = null;
    let bestScore = 0;
    for (const topic of topics) {
      const score = window.ayanFloatingMatchFn(q, topic.triggerKeywords, topic.strongKeywords || []);
      if (score > bestScore) {
        bestScore = score;
        best = topic;
      }
    }
    return bestScore > 0 ? best : null;
  }

  function showResult(topic) {
    if (!topic) return;
    fallbackEl.hidden = true;
    quickSection.hidden = true;

    topicEl.textContent = "专题：" + topic.label;
    suggestionEl.textContent = topic.suggestion;

    const shown = topic.articles ? topic.articles.slice(0, 2) : [];
    if (shown.length > 0) {
      articlesEl.innerHTML = shown.map(function (a) {
        return '<a class="ayan-floating-article" href="/articles/' + a.slug + '/" target="_blank" rel="noopener noreferrer">' +
          '<span class="ayan-floating-article-title">' + a.title + '</span>' +
          '<span class="ayan-floating-article-desc">' + a.desc + '</span></a>';
      }).join("");
    } else {
      articlesEl.innerHTML = "";
    }

    resultEl.hidden = false;
  }

  function showFallback() {
    resultEl.hidden = true;
    quickSection.hidden = true;
    fallbackEl.hidden = false;
  }

  function runAsk(query) {
    const q = String(query || "").trim();
    if (!q) return;
    const topic = matchTopic(q);
    if (topic) {
      showResult(topic);
    } else {
      showFallback();
    }
  }

  trigger.addEventListener("click", function (e) {
    e.preventDefault();
    openPanel();
  });

  closeBtn.addEventListener("click", closePanel);

  document.addEventListener("click", function (e) {
    if (panel.hidden) return;
    if (wrap && !wrap.contains(e.target)) {
      closePanel();
    }
  });

  askBtn.addEventListener("click", function () {
    runAsk(input.value);
  });

  input.addEventListener("keydown", function (e) {
    if (e.key === "Enter") runAsk(input.value);
  });

  quickBtns.forEach(function (btn) {
    btn.addEventListener("click", function () {
      var q = btn.getAttribute("data-ask");
      input.value = q;
      runAsk(q);
    });
  });
</script>

<style>
  .ayan-floating-wrap {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .ayan-floating-trigger {
    width: 140px;
    padding: 12px 16px;
    border-radius: 999px;
    background: linear-gradient(135deg, #2d7aff, #1560f0);
    color: #fff;
    border: 1px solid rgba(125, 185, 255, 0.20);
    box-shadow: 0 8px 32px rgba(21, 96, 240, 0.30);
    cursor: pointer;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    text-align: center;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .ayan-floating-trigger:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 12px 40px rgba(21, 96, 240, 0.40);
  }

  .ayan-floating-trigger-title {
    font-weight: 900;
    font-size: 14px;
  }

  .ayan-floating-trigger-text {
    display: none;
  }

  .ayan-floating-panel {
    position: absolute;
    bottom: calc(100% + 12px);
    right: 0;
    width: 380px;
    max-height: min(560px, 80vh);
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 24px 80px rgba(2, 10, 24, 0.28);
    border: 1px solid rgba(226, 232, 240, 0.96);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ayan-floating-panel[hidden] {
    display: none !important;
  }

  .ayan-floating-wrap.is-open .ayan-floating-trigger {
    display: none;
  }

  .ayan-floating-head {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 20px 20px 0;
    flex-shrink: 0;
  }

  .ayan-floating-head div {
    flex: 1;
    min-width: 0;
  }

  .ayan-floating-title {
    font-size: 18px;
    font-weight: 900;
    color: #0f172a;
    margin-bottom: 6px;
  }

  .ayan-floating-subtitle {
    font-size: 13px;
    color: #64748b;
    line-height: 1.6;
  }

  .ayan-floating-close {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 999px;
    border: 0;
    background: #f1f5f9;
    color: #64748b;
    font-size: 20px;
    cursor: pointer;
    display: grid;
    place-items: center;
    font-family: inherit;
    transition: background 0.15s ease;
  }

  .ayan-floating-close:hover {
    background: #e2e8f0;
    color: #0f172a;
  }

  .ayan-floating-body {
    padding: 16px 20px;
    overflow-y: auto;
    flex: 1;
  }

  .ayan-floating-input-row {
    display: grid;
    grid-template-columns: 1fr 76px;
    gap: 8px;
  }

  .ayan-floating-input-row input {
    width: 100%;
    height: 42px;
    border-radius: 12px;
    border: 1px solid #dce6f5;
    background: #fff;
    color: #0f172a;
    font-size: 14px;
    padding: 0 12px;
    outline: none;
    box-sizing: border-box;
    font-family: inherit;
  }

  .ayan-floating-input-row input:focus {
    border-color: #1368ff;
    box-shadow: 0 0 0 3px rgba(19, 104, 255, 0.10);
  }

  .ayan-floating-input-row button {
    height: 42px;
    border: 0;
    border-radius: 12px;
    background: linear-gradient(135deg, #1368ff, #2563eb);
    color: #fff;
    font-size: 14px;
    font-weight: 900;
    cursor: pointer;
    font-family: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .ayan-floating-input-row button:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(19, 104, 255, 0.22);
  }

  .ayan-floating-quick {
    margin-top: 14px;
  }

  .ayan-floating-quick-label {
    font-size: 12px;
    color: #94a3b8;
    margin-bottom: 8px;
    font-weight: 700;
  }

  .ayan-floating-quick {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .ayan-floating-quick button {
    border: 1px solid #dceaff;
    background: #eef5ff;
    color: #1368ff;
    border-radius: 999px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 800;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
    font-family: inherit;
  }

  .ayan-floating-quick button:hover {
    border-color: #93c5fd;
    background: #e0edff;
  }

  .ayan-floating-result {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid #e2e8f0;
  }

  .ayan-floating-result-topic {
    display: inline-flex;
    align-items: center;
    height: 24px;
    padding: 0 10px;
    border-radius: 999px;
    background: #eef5ff;
    color: #1368ff;
    border: 1px solid #cfe0ff;
    font-size: 12px;
    font-weight: 900;
    margin-bottom: 10px;
  }

  .ayan-floating-result-suggestion {
    color: #0f172a;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .ayan-floating-article {
    display: block;
    padding: 10px 12px;
    border-radius: 12px;
    background: #f8fafc;
    border: 1px solid #e6eaf2;
    text-decoration: none;
    margin-bottom: 8px;
    transition: border-color 0.15s ease;
  }

  .ayan-floating-article:hover {
    border-color: rgba(19, 104, 255, 0.34);
  }

  .ayan-floating-article-title {
    display: block;
    color: #0f172a;
    font-size: 13px;
    font-weight: 800;
    line-height: 1.5;
    margin-bottom: 2px;
  }

  .ayan-floating-article-desc {
    display: block;
    color: #64748b;
    font-size: 12px;
    line-height: 1.5;
  }

  .ayan-floating-fallback {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid #e2e8f0;
  }

  .ayan-floating-fallback-text {
    color: #64748b;
    font-size: 14px;
    margin: 0 0 10px;
    line-height: 1.6;
  }

  .ayan-floating-fallback-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .ayan-floating-fallback-btns button {
    border: 1px solid #dceaff;
    background: #eef5ff;
    color: #1368ff;
    border-radius: 999px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 800;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
    font-family: inherit;
  }

  .ayan-floating-fallback-btns button:hover {
    border-color: #93c5fd;
    background: #e0edff;
  }

  .ayan-floating-footer {
    display: flex;
    gap: 0;
    border-top: 1px solid #e2e8f0;
    flex-shrink: 0;
  }

  .ayan-floating-footer-link {
    flex: 1;
    display: block;
    padding: 12px 14px;
    text-align: center;
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
    color: #1368ff;
    transition: background 0.15s ease;
  }

  .ayan-floating-footer-link:first-child {
    border-right: 1px solid #e2e8f0;
  }

  .ayan-floating-footer-link:hover {
    background: #f8fafc;
  }

  @media (max-width: 720px) {
    .ayan-floating-wrap {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .ayan-floating-panel {
      width: calc(100vw - 32px);
      right: -10px;
    }
  }
</style>
