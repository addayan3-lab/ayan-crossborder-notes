---
import { getCollection } from "astro:content";
import { getLearningPathArticles } from "../lib/content-orchestration";

export interface Props {
  topic: string;
}

const { topic } = Astro.props;

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const { primary, secondary } = getLearningPathArticles(allPosts, topic);
---

{primary.length > 0 && (
  <div class="lp-section">
    <h3>按阅读顺序</h3>
    <ul class="lp-list">
      {primary.map((a) => (
        <li>
          <a href={a.href}>
            {a.title}
            {a.pathLabel && <span class="lp-label">{a.pathLabel}</span>}
          </a>
        </li>
      ))}
    </ul>
  </div>
)}

{secondary.length > 0 && (
  <div class="lp-section">
    <h3>辅助阅读</h3>
    <ul class="lp-list">
      {secondary.map((a) => (
        <li>
          <a href={a.href}>
            {a.title}
            {a.pathLabel && <span class="lp-label">{a.pathLabel}</span>}
          </a>
        </li>
      ))}
    </ul>
  </div>
)}

<style>
  .lp-section {
    margin-bottom: 20px;
  }

  .lp-section h3 {
    margin: 0 0 12px;
    font-size: 17px;
    font-weight: 900;
    color: #0f172a;
  }

  .lp-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .lp-list li {
    margin: 0;
  }

  .lp-list a {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    color: #1e3a5f;
    font-size: 15px;
    line-height: 1.6;
    font-weight: 600;
    padding: 10px 14px;
    border-radius: 10px;
    background: #f3f7ff;
    border: 1px solid #e3edff;
    text-decoration: none;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .lp-list a:hover {
    background: #e6efff;
    border-color: rgba(19, 104, 255, 0.32);
    color: #1368ff;
  }

  .lp-list a::before {
    content: "▸";
    color: #1368ff;
    font-size: 12px;
    font-weight: 900;
    flex-shrink: 0;
  }

  .lp-label {
    display: inline-flex;
    align-items: center;
    height: 22px;
    padding: 0 8px;
    border-radius: 999px;
    background: #eef5ff;
    color: #1368ff;
    border: 1px solid #cfe0ff;
    font-size: 11px;
    font-weight: 900;
    white-space: nowrap;
  }
</style>
